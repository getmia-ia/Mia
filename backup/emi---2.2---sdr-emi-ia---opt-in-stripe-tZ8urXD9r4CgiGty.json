    {
      "parameters": {
        "jsCode": "const c = items[0].json;\nconst raw = String(c.phone || (c.metadata && c.metadata.whatsapp) || '').trim();\nconst digits = raw.replace(/\\D/g, ''); // E.164 sem '+'\n\nif (!digits) {\n  // sem telefone: não envia, só loga\n  return [{ json: { skip: true, reason: 'no_phone', customer_id: c.id, sub_id: $json.sub_id || null } }];\n}\n\nconst first = (c.name || '').split(/\\s+/)[0] || '';\nconst text = `Oi ${first}, sua assinatura foi criada ✅\nVocê começará a receber o Journal por WhatsApp. Qualquer coisa, pode me chamar!`;\n\nreturn [{ json: { number: digits, text } }];\n"
      },
