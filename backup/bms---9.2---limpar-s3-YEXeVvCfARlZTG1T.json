    {
      "parameters": {
        "jsCode": "// Obter configurações - com debug\nconst configNode = $('Configurações do S3').first().json;\nconst maxAgeDays = parseInt(configNode.maxAgeDays) || parseInt(configNode.MaxAgeDays) || 7;\n\n// Obter item atual\nconst item = $input.item;\nconst fileKey = item.json.Key;\n\n// Extrair a data do nome do arquivo\n// Formato esperado: MIA/1.1/20251217083238912.png\n// Extrair apenas os 8 primeiros dígitos da data (YYYYMMDD)\nconst regex = /\\/(\\d{8})\\d+\\./;\nconst match = fileKey.match(regex);\n\nif (!match) {\n  // Se não conseguir extrair a data, retorna que não é antigo\n  return {\n    json: {\n      ...item.json,\n      isOld: false,\n      error: 'Não foi possível extrair a data do nome do arquivo',\n      dateExtracted: null,\n      ageInDays: null,\n      cutoffDate: null\n    }\n  };\n}\n\n// Pegar a data extraída (YYYYMMDD)\nconst dateString = match[1]; // Ex: \"20251217\"\nconst year = parseInt(dateString.substring(0, 4));\nconst month = parseInt(dateString.substring(4, 6));\nconst day = parseInt(dateString.substring(6, 8));\n\n// Criar objeto Date da data do arquivo\nconst fileDate = new Date(year, month - 1, day);\nfileDate.setHours(0, 0, 0, 0);\n\n// Calcular data de corte (hoje - maxAgeDays)\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst cutoffDate = new Date(today);\ncutoffDate.setDate(today.getDate() - maxAgeDays);\n\n// Calcular diferença em dias\nconst diffTime = today.getTime() - fileDate.getTime();\nconst ageInDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));\n\n// Verificar se o arquivo é antigo\n// MANTER arquivos com maxAgeDays ou menos\n// DELETAR arquivos com mais de maxAgeDays\nconst isOld = ageInDays > maxAgeDays;\n\n// Formatar datas para exibição\nconst formatDate = (date) => {\n  const y = date.getFullYear();\n  const m = String(date.getMonth() + 1).padStart(2, '0');\n  const d = String(date.getDate()).padStart(2, '0');\n  return `${y}-${m}-${d}`;\n};\n\n// Retornar resultado com informações detalhadas\nreturn {\n  json: {\n    ...item.json,\n    isOld: isOld,\n    dateExtracted: formatDate(fileDate),\n    cutoffDate: formatDate(cutoffDate),\n    ageInDays: ageInDays,\n    maxAgeDaysUsed: maxAgeDays,\n    fileName: fileKey.split('/').pop()\n  }\n};"
      },
