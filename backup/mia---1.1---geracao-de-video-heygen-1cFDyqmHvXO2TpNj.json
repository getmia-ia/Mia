      "id": "69590dd3-1d39-4e62-a43d-86925c9246e4",
      "name": "Salvar video na VPS"
    },
    {
      "parameters": {
        "command": "=set -e\n\nWD=\"/tmp/n8n/{{$workflow.id}}/{{$execution.id}}\"\nIN=\"$WD/in.mp4\"\nOUT=\"$WD/out.mp4\"\nSUB=\"$WD/srt.srt\"\nBGM=\"/home/node/.n8n/assets/trilha_finamob.mp3\"\n\nmkdir -p \"$WD\"\n[ -s \"$IN\" ] || { echo \"ERRO: input não encontrado: $IN\"; exit 1; }\n\n# Recorta para 9:16 e dá upscale para 1080x1920\nVF=\"crop=in_h*9/16:in_h:(in_w-in_h*9/16)/2:0,scale=1080:1920\"\n\n# Embute SRT se existir (escapa path p/ filtro subtitles)\nif [ -s \"$SUB\" ]; then\n  ESC_SUB=\"$(printf \"%s\" \"$SUB\" | sed -e 's/\\\\/\\\\\\\\/g' -e 's/:/\\\\:/g' -e \"s/'/\\\\\\\\'/g\")\"\n  VF=\"$VF,subtitles='$ESC_SUB':charenc=UTF-8\"\n  echo \"Legenda encontrada em $SUB - será embutida.\"\nelse\n  echo \"AVISO: legenda não encontrada em $SUB; seguindo sem SRT.\"\nfi\n\nif [ -s \"$BGM\" ]; then\n  # Com trilha: mixa a voz do vídeo (0:a) com a trilha (1:a) em ~18%\n  ffmpeg -hide_banner -y \\\n    -i \"$IN\" \\\n    -stream_loop -1 -i \"$BGM\" \\\n    -vf \"$VF\" \\\n    -filter_complex \"[1:a]volume=0.18[bg];[0:a][bg]amix=inputs=2:duration=shortest:dropout_transition=2[a]\" \\\n    -map 0:v -map \"[a]\" \\\n    -c:v libx264 -preset veryfast -crf 22 -pix_fmt yuv420p \\\n    -c:a aac -b:a 192k -shortest -movflags +faststart \\\n    \"$OUT\"\nelse\n  # Sem trilha: usa só áudio do vídeo (ou nenhum, se não houver)\n  ffmpeg -hide_banner -y \\\n    -i \"$IN\" \\\n    -vf \"$VF\" \\\n    -map 0:v -map 0:a? \\\n    -c:v libx264 -preset veryfast -crf 22 -pix_fmt yuv420p \\\n    -c:a aac -b:a 192k -shortest -movflags +faststart \\\n    \"$OUT\"\nfi\n\nprintf %s \"$OUT\"\n"
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        3040,
