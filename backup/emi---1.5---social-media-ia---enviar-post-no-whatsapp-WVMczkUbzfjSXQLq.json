    {
      "parameters": {
        "jsCode": "// Pega todas as linhas\nconst rows = items.map(i => i.json);\n\n// Função pra checar se está aprovado\nconst isApproved = v => String(v || '').trim().toLowerCase() === 'postado';\n\n// Acha o primeiro item aprovado\nconst first = rows.find(r => isApproved(r.status));\n\nif (!first) return [];\n\nreturn [{ json: { ...first, status_retorno: first.status } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        16
      ],
      "id": "644d5f6f-8ee9-452d-99fa-536465facd3b",
      "name": "Pega primeiro item aprovado"
    },
    {
      "parameters": {
        "jsCode": "// Executar: Run Once for Each Item\nconst post = $json;\n\n// 1️⃣ Dados principais\nconst legenda = post.legenda_instagram || '';\nconst url = post.imagem1_url;\nif (!url) throw new Error('Campo imagem1_url está vazio.');\n\n// 2️⃣ Baixar a imagem (modo compatível)\nconst buffer = await this.helpers.httpRequest({\n  method: 'GET',\n  url,\n  encoding: null, // recebe binário\n  responseFormat: 'file', // força retorno de arquivo\n});\n\n// 3️⃣ Detectar MIME Type\n// Alguns S3/CDN não enviam content-type, então definimos padrão\nconst mimeType =\n  (buffer.headers && buffer.headers['content-type']) ||\n  'image/jpeg';\n\n// 4️⃣ Converter para Base64\nconst base64 = Buffer.from(buffer).toString('base64');\nconst base64WithPrefix = `data:${mimeType};base64,${base64}`;\n\n// 5️⃣ Retornar resultado completo\nreturn [\n  {\n    json: {\n      id_post: post.id_post,\n      legenda,\n      imagem_url: url,\n      mimeType,\n      base64,\n      base64WithPrefix,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
