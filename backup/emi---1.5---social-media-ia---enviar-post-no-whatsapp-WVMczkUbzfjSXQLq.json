    {
      "parameters": {
        "jsCode": "const COUNTRY = '55';\nconst onlyDigits = s => String(s ?? '').replace(/\\D/g, '').replace(/^0+/, '');\nconst toE164NoPlus = d => d ? (d.startsWith(COUNTRY) ? d : COUNTRY + d) : '';\nconst toJid = e164 => e164 ? `${e164}@s.whatsapp.net` : '';\n\nconst out = [];\nconst seen = new Set();\n\nfor (const { json } of items) {\n\n  // captura telefone do JSON (número ou string)\n  const rawPhone = json.telefone ?? json.phone ?? json.phone_raw ?? '';\n  const rawDigits = onlyDigits(rawPhone);\n\n  if (!rawDigits) continue;\n\n  const e164 = toE164NoPlus(rawDigits);\n  if (!e164) continue;\n\n  // impede duplicados\n  if (seen.has(e164)) continue;\n  seen.add(e164);\n\n  const firstName = String(json.nome || json.name || '')\n    .trim()\n    .split(/\\s+/)[0] || '';\n\n  out.push({\n    json: {\n      ...json,\n      e164,               // 5511999999999\n      jid: toJid(e164),   // 5511999999999@s.whatsapp.net\n      firstName\n    }\n  });\n}\n\nreturn out;\n"
      },
