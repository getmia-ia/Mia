    {
      "parameters": {
        "jsCode": "const padKeys = {\n  \"codigo_sku\": \"Código (SKU)\",\n  \"produto\": \"Produto\",\n  \"preco\": \"Preço\",\n  \"estoque_atual\": \"Estoque atual\",\n  \"estoque_disponivel\": \"Estoque disponível\",\n  \"unidade\": \"UN\",\n  \"localizacao\": \"Localização\"\n};\n\nconst numericFields = [\n  \"preco\",\n  \"estoque_atual\",\n  \"estoque_disponivel\"\n];\n\n// Função para converter número (de vírgula pra ponto)\nfunction formatNumber(input) {\n  if (!input || typeof input !== 'string') return input;\n  return input.replace(/\\./g, '').replace(',', '.');\n}\n\n// 📁 Pega o nome do arquivo corretamente do nó \"Download file\"\nconst fileName = $('Download file').first().json.name || 'desconhecido.csv';\nconst filial = fileName.replace('.csv', '').trim(); // exemplo: \"03\"\n\n// 🚀 Processa todos os itens\nreturn $input.all().map(item => {\n  const raw = item.json;\n  const normalized = {};\n\n  for (const [key, originalName] of Object.entries(padKeys)) {\n    let value = raw[originalName] ?? '';\nif (numericFields.includes(key)) {\n  value = value === '' ? null : formatNumber(value);\n}\n    normalized[key] = value;\n  }\n\n  // ➕ Adiciona o nome da filial\n  normalized.filial = filial;\n\n  return { json: normalized };\n});\n"
      },
