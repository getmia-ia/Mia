        "jsCode": "const padKeys = {\n  \"id\": \"ID\",\n  \"numero_do_pedido\": \"Número do pedido\",\n  \"data\": \"Data\",\n  \"data_prevista\": \"Data prevista\",\n  \"id_contato\": \"ID contato\",\n  \"nome_do_contato\": \"Nome do contato\",\n  \"tipo_de_pessoa\": \"Tipo de Pessoa\",\n  \"cpf_cnpj\": \"CPF/CNPJ\",\n  \"rg_ie\": \"RG/IE\",\n  \"cep\": \"CEP\",\n  \"municipio\": \"Municí­pio\",\n  \"uf\": \"UF\",\n  \"endereco\": \"Endereço\",\n  \"endereco_nro\": \"Endereço Nro\",\n  \"complemento\": \"Complemento\",\n  \"bairro\": \"Bairro\",\n  \"fone\": \"Fone\",\n  \"celular\": \"Celular\",\n  \"email\": \"e-mail\",\n  \"desconto_do_pedido_porcento_ou_valor\": \"Desconto do pedido (% ou valor)\",\n  \"frete_pedido\": \"Frete pedido\",\n  \"observacoes\": \"Observações\",\n  \"situacao\": \"Situação\",\n  \"id_produto\": \"ID produto\",\n  \"descricao\": \"Descrição\",\n  \"quantidade\": \"Quantidade\",\n  \"valor_unitario\": \"Valor unitário\",\n  \"desconto_item\": \"Desconto item\",\n  \"codigo_de_rastreamento\": \"Código de rastreamento\",\n  \"numero_da_ordem_de_compra\": \"Número da ordem de compra\",\n  \"vendedor\": \"Vendedor\",\n  \"despesas_pedido\": \"Despesas pedido\",\n  \"desconto_pedido_rateado\": \"Desconto do pedido rateado\",\n  \"frete_pedido_rateado\": \"Frete pedido rateado\",\n  \"despesas_pedido_rateado\": \"Despesas pedido rateado\",\n  \"destinatario\": \"Destinatário\",\n  \"cpf_cnpj_entrega\": \"CPF/CNPJ entrega\",\n  \"cep_entrega\": \"CEP entrega\",\n  \"municipio_entrega\": \"Municí­pio entrega\",\n  \"uf_entrega\": \"UF entrega\",\n  \"endereco_entrega\": \"Endereço entrega\",\n  \"endereco_nro_entrega\": \"Endereço Nro entrega\",\n  \"complemento_entrega\": \"Complemento entrega\",\n  \"bairro_entrega\": \"Bairro entrega\",\n  \"fone_entrega\": \"Fone entrega\",\n  \"codigo_sku\": \"Código (SKU)\"\n};\n\n// Campos numéricos que precisam ser convertidos\nconst numericFields = [\n  \"desconto_do_pedido_porcento_ou_valor\",\n  \"frete_pedido\",\n  \"valor_unitario\",\n  \"desconto_item\",\n  \"despesas_pedido\",\n  \"desconto_pedido_rateado\",\n  \"frete_pedido_rateado\",\n  \"despesas_pedido_rateado\",\n  \"quantidade\"\n];\n\n// Converte data de DD/MM/YYYY → YYYY-MM-DD\nfunction formatDateBRtoISO(input) {\n  if (!input || typeof input !== 'string') return null;\n  const [day, month, year] = input.split('/');\n  if (!day || !month || !year) return null;\n  return `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;\n}\n\n// Converte valores numéricos com vírgula para ponto\nfunction formatNumber(input) {\n  if (!input || typeof input !== 'string') return input;\n\n  return input\n    .replace(/%/g, '')      // remove o %\n    .replace(/\\s+/g, '')    // remove espaços\n    .replace(/\\./g, '')     // remove milhar\n    .replace(',', '.');     // vírgula -> ponto\n}\n\nreturn $input.all().map(item => {\n  const raw = item.json;\n  const normalized = {};\n\n  for (const [key, originalName] of Object.entries(padKeys)) {\n    let value = raw[originalName] ?? '';\n\n    // Converte datas\n    if (key === 'data' || key === 'data_prevista') {\n      value = formatDateBRtoISO(value);\n    }\n\n    // Converte campos numéricos\n    if (numericFields.includes(key)) {\n      value = formatNumber(value);\n    }\n\n    normalized[key] = value;\n  }\n\n  // Adiciona campo fixo da filial\n  normalized.filial = \"04\";\n\n  return { json: normalized };\n});\n"
      },
