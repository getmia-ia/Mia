      "name": "Sticky Note"
    },
    {
      "parameters": {
        "jsCode": "function padronizarTelefone(raw) {\n  if (!raw) return null;\n\n  // Remove tudo que não é número\n  let t = raw.toString().replace(/\\D/g, \"\");\n\n  // Remove zeros iniciais (caso venha \"011...\")\n  t = t.replace(/^0+/, \"\");\n\n  // Caso 1: só 8 dígitos → falta DDD e falta 9\n  if (t.length === 8) {\n    t = \"11\" + \"9\" + t;\n  }\n\n  // Caso 2: 9 dígitos → falta DDD\n  if (t.length === 9) {\n    t = \"11\" + t;\n  }\n\n  // Caso 3: DDD + fixo (10 dígitos) → insere 9\n  if (t.length === 10) {\n    t = t.replace(/^(\\d{2})(\\d{8})$/, \"$19$2\");\n  }\n\n  // Caso 4: DDD + celular (11 dígitos) → falta o 55\n  if (t.length === 11) {\n    t = \"55\" + t;\n  }\n\n  // Caso 5: 55 + DDD + fixo (12 dígitos) → insere 9\n  if (t.length === 12) {\n    t = t.slice(0, 4) + \"9\" + t.slice(4);\n  }\n\n  // Caso 6: 55 + DDD + celular (13 dígitos) → OK\n  if (t.length === 13) {\n    return t;\n  }\n\n  // Caso 7: números muito longos → pega os últimos 13\n  if (t.length > 13) {\n    t = t.slice(-13);\n  }\n\n  return t;\n}\n\n// ==========================\n// PROCESSAMENTO CORRETO\n// ==========================\n\nconst input = $input.all();\n\nreturn input.map(item => {\n  const original = item.json.Contato;\n  const ajustado = padronizarTelefone(original);\n\n  return {\n    json: {\n      ...item.json,\n      contatoAjustado: ajustado\n    }\n  };\n});\n"
      },
