    {
      "parameters": {
        "jsCode": "// Acessa a memória global deste workflow específico\nconst staticData = $getWorkflowStaticData('global');\n\n// Tenta ler 'fromStart' do Webhook ou do HTTP Request anterior\n// O ?. garante que se não houver dados, ele não quebra (retorna undefined)\nconst inputData = $input.first()?.json;\nconst isInitial = inputData?.fromStart === true || inputData?.trigger === 'start';\n\n// Se for o comando de início, reseta. Se não, mantém o que está na memória.\nif (isInitial) {\n  staticData.offset = 0;\n}\n\n// Retorna o valor para o nó do Postgres usar\nreturn [{ \n  json: { \n    offset: staticData.offset || 0 \n  } \n}];"
      },
