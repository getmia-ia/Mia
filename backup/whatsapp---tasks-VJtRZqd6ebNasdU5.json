      "name": "É mensagem de texto recebida?"
    },
    {
      "parameters": {
        "jsCode": "// ==== Parser da mensagem do WhatsApp (Evolution API) ====\nconst body = $input.first().json.body || $input.first().json;\nconst data = body?.data || {};\nconst key = data.key || {};\n\n// ---- Texto da mensagem ----\nconst rawMessage = (\n  data.message?.conversation ||\n  data.message?.extendedTextMessage?.text ||\n  ''\n).trim();\n\n// ---- Grupo vs 1:1 ----\nconst remoteJid = key.remoteJid || '';\nconst isGrupo = remoteJid.endsWith('@g.us');\n\n// ---- Quem enviou (telefone real, tratando LID) ----\nlet jidRemetente = isGrupo\n  ? (key.participantAlt || key.participant || '')\n  : (key.participantAlt || remoteJid || '');\nconst isLid = jidRemetente.endsWith('@lid');\nlet from = jidRemetente.split('@')[0].replace(/\\D/g, '');\nif (!isLid && from.length === 12 && from.startsWith('55')) {\n  from = from.slice(0, 4) + '9' + from.slice(4);\n}\n\n// ---- Onde responder ----\nconst respostaJid = remoteJid;\n\n// ---- Mensagem citada (quote) ----\nconst ctx = data.contextInfo || data.message?.extendedTextMessage?.contextInfo || null;\nconst quoted = ctx?.quotedMessage || null;\nlet textoCitado = '';\nif (quoted) {\n  textoCitado = (\n    quoted.conversation ||\n    quoted.extendedTextMessage?.text ||\n    quoted.imageMessage?.caption ||\n    quoted.videoMessage?.caption ||\n    ''\n  ).trim();\n}\n\n// ---- Detecta comando ----\nconst parts = rawMessage.split(/\\s+/);\nconst first = parts[0] || '';\nconst command = first.startsWith('/') ? first.toLowerCase() : '';\n\n// Tudo depois do comando\nconst resto = rawMessage.slice(first.length).trim();\n\n// Separa as tags (#chave:valor) do título\nconst tags = {};\nconst tagRegex = /#(\\w+):(\\S+)/g;\nlet m;\nwhile ((m = tagRegex.exec(resto)) !== null) {\n  tags[m[1].toLowerCase()] = m[2];\n}\n\n// Título = o resto SEM as tags\nlet titleDigitado = resto.replace(/#\\w+:\\S+/g, '').trim();\n\n// ---- Regra do quote ----\n// Se for /task, não há título digitado (só tags ou nada), e existe quote,\n// usa o texto citado como título.\nlet title = titleDigitado;\nif (command === '/task' && !titleDigitado && textoCitado) {\n  title = textoCitado;\n}\n\nreturn [{\n  json: {\n    from,\n    raw_message: rawMessage,\n    command,\n    title,\n    tags,                        // { org: 'Eleva', area: 'Plataforma' }\n    org: tags.org || '',\n    area: tags.area || '',\n    texto_citado: textoCitado,\n    usou_quote: command === '/task' && !titleDigitado && !!textoCitado,\n    resposta_jid: respostaJid,\n    is_grupo: isGrupo,\n    pusher_name: data.pushName || '',\n    is_command: !!command\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -224,
        112
      ],
      "id": "2d4e1e61-8026-4141-a945-cf8fdbfc0d9f",
      "name": "Parse do comando"
    },
