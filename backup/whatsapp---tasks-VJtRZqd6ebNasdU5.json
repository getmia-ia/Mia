      "id": "3a3ad85c-e02b-4272-870a-efecae605f51",
      "name": "Comando válido?"
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst parse = $('Parse do comando').first().json;\n\nconst AJUDA =\n  '📋 *Comandos disponíveis:*\\n\\n' +\n  '• /task Descrição #area:Marketing — cria uma tarefa\\n' +\n  '• /hoje — suas tarefas de hoje\\n' +\n  '• /done <id> — concluir tarefa\\n' +\n  '• /ajuda — mostra esta mensagem';\n\nlet mensagem;\n\n// Se o comando foi /ajuda, responde a lista direto (não depende da função)\nif (parse.command === '/ajuda') {\n  mensagem = AJUDA;\n} else if (resp && typeof resp.reply === 'string' && resp.reply.length > 0) {\n  mensagem = resp.reply;\n} else if (resp && resp.ok === false) {\n  let motivo = resp.error || 'erro desconhecido';\n  if (resp.details) {\n    motivo += ' (campos: ' + Object.keys(resp.details).join(', ') + ')';\n  }\n  mensagem = '⚠️ Não consegui processar seu comando.\\nMotivo: ' + motivo;\n} else {\n  mensagem = '⚠️ Ocorreu um erro inesperado. Tente novamente.';\n}\n\nreturn [{\n  json: {\n    mensagem_resposta: mensagem,\n    from: parse.from\n  }\n}];"
      },
