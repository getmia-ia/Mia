      {
        "parameters": {
          "jsCode": "const p = $input.first().json;\n\nlet valido = true;\nlet erro = '';\n\n// Lista dos únicos comandos que o bot responde\nconst comandosValidos = ['/task', '/hoje', '/done', '/ajuda'];\n\n// ⛔ Não é comando (não começa com /) OU é um comando fora da lista → ignora TUDO\nif (!p.is_command || !comandosValidos.includes(p.command)) {\n  return [{ json: { ...p, valido: false, erro_validacao: '' } }];\n}\n\n// A partir daqui, é garantidamente um dos 4 comandos.\n\nif (p.command === '/task') {\n  if (!p.org) {\n    valido = false;\n    erro =\n      '⚠️ Faltou a organização.\\n\\n' +\n      'Use: /task Descrição #org:NomeDaOrg #area:NomeDaArea\\n' +\n      'Exemplo: /task Corrigir bug #org:Eleva #area:Plataforma';\n  } else if (!p.title) {\n    valido = false;\n    erro =\n      '⚠️ Faltou a descrição da tarefa.\\n\\n' +\n      'Digite o texto após /task, ou responda a uma mensagem com /task.';\n  }\n} else if (p.command === '/done') {\n  const codigo = (p.title || '').trim().split(/\\s+/)[0] || '';\n  if (!codigo) {\n    valido = false;\n    erro =\n      '⚠️ Faltou o código da tarefa.\\n\\n' +\n      'Use: /done <código>\\nExemplo: /done 0232\\nVeja os códigos com /hoje.';\n  }\n}\n\nreturn [{\n  json: { ...p, valido, erro_validacao: erro }\n}];"
        },
