    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (!items.length) return [];\n\n// Pega o primeiro item que tenha histórico\nconst histItem = items.find(item => item.json?.historico);\nconst historico = histItem?.json?.historico || '';\n\n// Limita tamanho\nconst hist = historico.length > 15000 ? historico.slice(0, 15000) : historico;\n\n// Filtra apenas itens que são notícias (tem noticia_id)\nconst noticias = items.filter(item => item.json?.noticia_id);\n\n// Se não há notícias, retorna vazio\nif (!noticias.length) return [];\n\n// Injeta histórico\nreturn noticias.map(noticia => ({\n  json: {\n    ...noticia.json,\n    historico: hist\n  }\n}));"
      },
