        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.output;\nconst parsed = JSON.parse(raw); // Isso vira um array com 1 objeto\n\n// Retorna o primeiro e único objeto do array\nreturn {\n  json: parsed[0]\n};\n"
