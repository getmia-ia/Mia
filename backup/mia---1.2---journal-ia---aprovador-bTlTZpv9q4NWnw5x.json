      "parameters": {
        "jsCode": "// Processa cada item do array de entrada\nreturn $input.all().map(item => {\n  // Cria array para armazenar as imagens\n  const imagens = [];\n  \n  // Itera enquanto encontrar imagens (não limita a quantidade)\n  let i = 1;\n  while (item.json[`imagem${i}_url`]) {\n    const imagemUrl = item.json[`imagem${i}_url`];\n    \n    // Adiciona a URL no array se existir\n    if (imagemUrl) {\n      imagens.push(imagemUrl);\n    }\n    \n    i++;\n  }\n  \n  // Retorna o array de URLs\n  return {\n    json: {\n      imagens: imagens\n    }\n  };\n});"
      },
