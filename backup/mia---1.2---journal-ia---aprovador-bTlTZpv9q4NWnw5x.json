    {
      "parameters": {
        "jsCode": "const DIAS = 3;\nconst corte = new Date(); \ncorte.setDate(corte.getDate() - DIAS);\n\nconsole.log('=== DEBUG HISTÓRICO ===');\nconsole.log('Data de corte:', corte.toISOString());\n\nfunction parseBR(v){\n  if (!v) return NaN;\n  if (v instanceof Date) return v;\n  const m = String(v).trim().match(/^(\\d{2})\\/(\\d{2})\\/(\\d{4})$/);\n  if (!m) return NaN;\n  const [_, dd, mm, yyyy] = m.map(Number);\n  return new Date(yyyy, mm-1, dd);\n}\n\n// Debug: ver todas as notícias recebidas\nconst todasNoticias = $input.all();\nconsole.log('Total notícias recebidas:', todasNoticias.length);\n\ntodasNoticias.forEach((noticia, index) => {\n  const j = noticia.json || {};\n  console.log(`Noticia ${index}:`, {\n    id: j.noticia_id,\n    status: j.status,\n    data: j.data_processamento || j.data_proce || j.data_proces || j.data,\n    titulo: j.titulo?.substring(0, 50) + '...'\n  });\n});\n\n// filtra últimos DIAS\nconst recentes = todasNoticias.filter(i => {\n  const j = i.json || {};\n  const raw = j.data_processamento || j.data_proce || j.data_proces || j.data;\n  const d = parseBR(raw);\n  const statusOk = (j.status || '').toLowerCase() === 'postado';\n  const dataOk = d instanceof Date && !isNaN(d) && d >= corte;\n  \n  console.log(`Filtro - ID: ${j.noticia_id}, Status: ${j.status}, Data: ${raw}, DataOK: ${dataOk}, StatusOK: ${statusOk}`);\n  \n  return dataOk && statusOk;\n});\n\nconsole.log('Notícias recentes encontradas:', recentes.length);\n\n// monta string\nlet historico = recentes.map(i => {\n  const j = i.json || {};\n  return `ID:${j.noticia_id} | ${j.titulo || ''} | ${j.legenda || ''}`;\n}).join('\\n');\n\nconsole.log('Histórico gerado:', historico.substring(0, 200) + '...');\n\n// limita tamanho (evita prompt gigante)\nif (historico.length > 15000) historico = historico.slice(0, 15000);\n\n// Se não há histórico, cria um vazio mas identificável\nif (!historico || historico.trim() === '') {\n  historico = 'Nenhuma notícia postada nos últimos 3 dias';\n  console.log('Histórico VAZIO - usando placeholder');\n}\n\n// retorna **um único item**\nreturn [{ \n  json: { \n    historico,\n    _debug: {\n      total_noticias: todasNoticias.length,\n      noticias_recentes: recentes.length,\n      data_corte: corte.toISOString()\n    }\n  } \n}];"
      },
