      ],
      "id": "48b924f1-9382-434e-939a-ee9b11bc30d7",
      "name": "Gera histórico",
      "alwaysOutputData": true,
      "disabled": true
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.merge",
