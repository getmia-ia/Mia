    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// 1. Pega os dados do Webhook ou do Schedule\nconst isInitialTrigger = $input.first().json.fromSchedule === true;\n\n// 2. LOGICA DE AUTO-CORREÇÃO (O pulo do gato)\n// Se o offset estiver acima de um número impossível (ex: 100.000) ou for o início:\nif (isInitialTrigger || (staticData.offset > 100000)) {\n  staticData.offset = 0;\n  staticData.phase = 'leads';\n  staticData.isDone = false;\n  console.log('🧹 Limpeza automática: Offset resetado para 0.');\n}\n\n// 3. Garante que os valores existam\nconst currentPhase = staticData.phase || 'leads';\nconst currentOffset = staticData.offset || 0;\n\nreturn [{\n  json: {\n    phase: currentPhase,\n    offset: currentOffset,\n    isDone: staticData.isDone || false,\n    fromSchedule: isInitialTrigger\n  }\n}];"
      },
