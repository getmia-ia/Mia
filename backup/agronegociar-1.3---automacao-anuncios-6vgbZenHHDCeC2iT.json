    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst items = $input.all();\n\n// Verifica se o primeiro item tem campos reais (evita o [{}] vazio)\nconst hasRealData = items.length > 0 && Object.keys(items[0].json).length > 0;\n\nif (hasRealData) {\n  staticData.offset += 500;\n  staticData.isDone = false;\n} else {\n  // Se veio vazio, reseta o offset e TROCA A FASE\n  staticData.offset = 0;\n  if (staticData.phase === 'anuncios') {\n    staticData.phase = 'leads';\n    staticData.isDone = false;\n  } else if (staticData.phase === 'leads') {\n    staticData.phase = 'usuarios';\n    staticData.isDone = false;\n  } else {\n    staticData.isDone = true;\n    staticData.phase = 'anuncios'; // Reseta para o próximo dia\n  }\n}\n\nreturn [{ json: { isDone: staticData.isDone, currentPhase: staticData.phase } }];"
      },
