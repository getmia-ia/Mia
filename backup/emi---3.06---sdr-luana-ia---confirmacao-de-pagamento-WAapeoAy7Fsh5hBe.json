              "value": "={{\n  (() => {\n    const produtoOriginal = $json.property_produto || \"\";\n    \n    const produtoNormalizado = produtoOriginal\n      .toLowerCase()\n      .normalize(\"NFD\")\n      .replace(/[\\u0300-\\u036f]/g, \"\")\n      .replace(/\\s+/g, \"\");\n\n    const produtosFemininos = [\"imersao\", \"mentoria\", \"escolaflix\"];\n\n    const preposicao = produtosFemininos.includes(produtoNormalizado)\n      ? \"na \"\n      : \"no \";\n\n    return preposicao + produtoOriginal;\n  })()\n}}",
