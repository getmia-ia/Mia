    {
      "parameters": {
        "jsCode": "const input = items[0].json.body;\n\nconst defensaId = input.defensaId;\nconst templateGoogleDocId = input.templateGoogleDocId;\n\n// aceita os dois formatos\nconst midias = input.midias || input.pdfsAnexos || [];\n\nfunction getTipoMidia(nome, url) {\n  const lower = (nome || url || \"\").toLowerCase();\n\n  if (lower.endsWith(\".pdf\")) return \"pdf\";\n\n  if (\n    lower.endsWith(\".jpg\") ||\n    lower.endsWith(\".jpeg\") ||\n    lower.endsWith(\".png\") ||\n    lower.endsWith(\".gif\") ||\n    lower.endsWith(\".webp\")\n  ) return \"img\";\n\n  return \"outro\";\n}\n\nreturn midias.map((m, index) => {\n  const tipo = getTipoMidia(m.nome, m.url);\n\n  return {\n    json: {\n      defensaId,\n      templateGoogleDocId,\n\n      midiaIndex: index,\n\n      url: m.url,\n      nome: m.nome,\n      tipo,\n      principal: m.principal || false,\n\n      isPdf: tipo === \"pdf\",\n      isImg: tipo === \"img\",\n\n      origem: \"upload\",\n\n      pageIndex: null,\n      totalPages: null\n    }\n  };\n});"
      },
