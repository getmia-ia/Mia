    },
    {
      "parameters": {
        "jsCode": "const RANGE_SIZE = 3;\n\nconst output = [];\n\nfor (const item of items) {\n\n  const pdf = item.json;\n\n  const totalPages = pdf.numpages || 1;\n\n  for (let page = 1; page <= totalPages; page += RANGE_SIZE) {\n\n    const pageFrom = page;\n\n    const pageTo = Math.min(\n      page + RANGE_SIZE - 1,\n      totalPages\n    );\n\n    output.push({\n      json: {\n\n        // mantém dados originais\n        defensaId: pdf.defensaId,\n        templateGoogleDocId: pdf.templateGoogleDocId,\n        midiaIndex: pdf.midiaIndex,\n        nome: pdf.nome,\n        url: pdf.url,\n\n        // info do chunk\n        totalPages,\n        page_from: pageFrom,\n        page_to: pageTo,\n\n        // identificador útil\n        chunk_id: `${pdf.midiaIndex}_${pageFrom}_${pageTo}`,\n\n        // opcional\n        is_last_chunk: pageTo === totalPages\n      }\n    });\n\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        -64
      ],
      "id": "48070dc6-e59b-4d9a-a5af-bf62ba354e9a",
      "name": "Range de pgs"
    },
    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  const conversionUrl = item.json.conversionUrl || \"\";\n\n  const urls = conversionUrl\n    .split(\",\")\n    .map(url => url.trim())\n    .filter(url => url.length > 0);\n\n  urls.forEach((url, index) => {\n    output.push({\n      json: {\n        defensaId: item.json.defensaId,\n        templateGoogleDocId: item.json.templateGoogleDocId,\n        pageIndex: index,\n        totalPages: urls.length,\n        url: url\n      }\n    });\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
