      "id": "18f3aebb-d353-47f0-933d-6aaa45caf916",
      "name": "When Executed by Another Workflow"
    },
    {
      "parameters": {
        "jsCode": "const resultados = [];\n\nfor (const item of $input.all()) {\n  try {\n    // 1. Pega a string que está dentro do campo \"query\"\n    const textoQuery = item.json.query;\n\n    // 2. Transforma a string de volta em um Objeto JSON real\n    const dadosExtraidos = JSON.parse(textoQuery);\n\n    // 3. Monta o item de saída limpo para o n8n\n    resultados.push({\n      json: {\n        // Extrai o telefone e o triagem_patch (se não vierem, joga vazio para não quebrar)\n        telefone: dadosExtraidos.telefone || \"\",\n        triagem_patch: dadosExtraidos.triagem_patch || {},\n        \n        // Pega a etapa se ela existir. Se a IA não mandar, define como string vazia \"\"\n        etapa: dadosExtraidos.etapa || \"\" \n      }\n    });\n\n  } catch (error) {\n    // Tratamento de erro: se a IA por acaso enviar algo que não seja JSON válido\n    resultados.push({\n      json: {\n        erro: \"Falha ao processar o JSON da triagem\",\n        detalhes: error.message,\n        input_original: item.json.query\n      }\n    });\n  }\n}\n\nreturn resultados;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
