      "id": "3102024e-8ea5-4c9d-8977-c7dd2c18226c",
      "name": "Webhook",
      "webhookId": "f057f629-ace7-4af0-b1a2-118353a1296c"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "e498d84f-6c83-4a33-8104-5fea5914b7cf",
              "name": "Nome",
              "value": "={{ $json.body.lead_data.full_name }}",
              "type": "string"
            },
            {
              "id": "a3d70d7b-7897-44f1-8d3a-ebc1551da964",
              "name": "Contato",
              "value": "={{\n(raw => {\n  let t = (raw || \"\").toString().replace(/\\s+/g, \"\").replace(/\\D/g, \"\");\n  t = t.replace(/^0+/, \"\");\n  if (t.length === 8) {\n    t = \"11\" + \"9\" + t;\n  } else if (t.length === 9) {\n    t = \"11\" + t;\n  } else if (t.length === 10) {\n    t = t.replace(/^(\\d{2})(\\d{8})$/, \"$19$2\");\n  } else if (t.length === 11) {\n    t = \"55\" + t;\n  } else if (t.length === 12) {\n    t = t.slice(0, 4) + \"9\" + t.slice(4);\n  } else if (t.length > 13) {\n    t = t.slice(-13);\n  }\n  return t;\n})($('Webhook').item.json.body.lead_data.phone)\n}}",
              "type": "string"
            },
            {
              "id": "8c323ed9-f71d-4d83-88af-1a0d6a57850f",
              "name": "E-mail",
              "value": "={{ $json.body.lead_data.email }}",
              "type": "string"
            },
            {
              "id": "5c1e2e2e-22f1-47d2-995b-a9f1822e3369",
              "name": "Etapa",
              "value": "Disparo Inicial",
              "type": "string"
            },
            {
              "id": "54aafe99-6e59-4f74-b330-530824a05ccc",
              "name": "Responsável",
              "value": "Gabriel",
              "type": "string"
            },
            {
              "id": "f6999fd1-3b33-44c6-a699-a29c4af8533c",
              "name": "Origem",
              "value": "Meta",
              "type": "string"
            },
            {
              "id": "c1893fe2-0e89-4801-bff1-4b2051ee8547",
              "name": "campanha",
              "value": "={{ $json.body.campaign.campaign_name }}",
              "type": "string"
            },
            {
              "id": "08076660-8d6d-4a49-96bd-d56541a58bbd",
              "name": "Produto",
              "value": "={{ \n  (() => {\n    const tag = $json.body.campaign.campaign_name\n      .match(/\\[(.*?)\\]/g)?.[1]\n      ?.replace(/[\\[\\]]/g, '')\n      ?.toLowerCase() || '';\n\n    return tag.charAt(0).toUpperCase() + tag.slice(1);\n  })()\n}}",
              "type": "string"
            }
          ]
        },
