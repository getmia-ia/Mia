      "position": [
        544,
        224
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all(); // Captura todos os itens de entrada\nconst dataFaceFormatted = [];\n\nitems.forEach(item => {\n  const data = item.json;\n\n  let mensagens = 0;\n  let linkClickValue = 0;\n  let compras = 0;\n\n  let sp = parseFloat(data.spend);  // Gasto\n  const impressions = parseInt(data.impressions || 0);\n  const reach = parseInt(data.reach || 0);\n\n  // Percorre todas as ações\n  if (data.actions) {\n    data.actions.forEach(action => {\n      const value = parseInt(action.value || 0);\n\n      if (action.action_type === 'onsite_conversion.messaging_conversation_started_7d') {\n        mensagens = value;\n      }\n\n      if (action.action_type === 'link_click') {\n        linkClickValue = value;\n      }\n\n      if (action.action_type === 'purchase') {\n        compras = value;  // Captura valor da ação \"purchase\"\n      }\n    });\n  }\n\n  // Calcula métricas\n  let custoPorMensagem = mensagens > 0 ? (sp / mensagens).toFixed(2).replace(\".\", \",\") : \"0,00\";\n  let cpc = linkClickValue > 0 ? (sp / linkClickValue).toFixed(2).replace(\".\", \",\") : \"0,00\";\n  let cpm = impressions > 0 ? (sp / (impressions / 1000)).toFixed(2).replace(\".\", \",\") : \"0,00\";\n  let frequencia = reach > 0 ? (impressions / reach).toFixed(2).replace(\".\", \",\") : \"0,00\";\n\n  dataFaceFormatted.push({\n    Data: data.date_start,\n    Campanha: data.campaign_name,\n    Gasto: sp.toFixed(2).replace(\".\", \",\"),\n    Mensagens: mensagens,\n    'Custo por Mensagens': custoPorMensagem,\n    Cliques: linkClickValue,\n    CPC: cpc,\n    Impressões: impressions,\n    CPM: cpm,\n    Alcance: reach,\n    Frequência: frequencia,\n    Compras: compras // ✅ Adicionado número de compras (purchase)\n  });\n});\n\nreturn dataFaceFormatted;"
      },
