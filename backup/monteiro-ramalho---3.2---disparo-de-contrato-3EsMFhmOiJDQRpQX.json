    {
      "parameters": {
        "method": "POST",
        "url": "https://api.zapsign.com.br/api/v1/docs/",
        "authentication": "***REMOVIDO***",
        "genericAuthType": "***REMOVIDO***",
        "sendHeaders": "***REMOVIDO***",
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": \"Contrato + Procuração\",\n  \"url_pdf\": \"{{ $json.url_pdf }}\",\n  \"disable_signer_emails\": true,\n  \"signers\": [\n    {\n      \"name\": \"Antonio Monteiro dos Santos Neto\",\n      \"email\": \"monteiro@monteiroramalho.adv.br\",\n      \"phone_country\": \"55\",\n      \"phone_number\": \"85987106731\",\n      \"send_automatic_email\": false\n    },\n    {\n      \"name\": \"{{ $json.nome_cliente }}\",\n      \"email\": \"{{ $json.email_cliente }}\",\n      \"phone_country\": \"55\",\n      \"phone_number\": \"{{ $json.telefone_cliente }}\",\n      \"send_automatic_email\": false\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        208,
        0
      ],
      "id": "7ce159d2-1806-4298-bdb2-e44063c324a5",
      "name": "ZapSign",
      "credentials": {
        "httpBearerAuth": "***REMOVIDO***"
      }
    },
    {
      "parameters": {
        "tableId": "historico_mensagens",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "mensagem_agente",
              "fieldValue": "={{ $('Saida do Agente').item.json.texto }}"
            },
            {
              "fieldId": "telefone",
