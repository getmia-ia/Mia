    {
      "parameters": {
        "jsCode": "const entrada = items[0].json;\n\nlet parameters = [];\n\nswitch (entrada.template) {\n  case \"confirmacao_presenca_1\":\n    // usa {{2}} → evento\n    parameters = [\n      { type: \"text\", text: String(entrada.var_2) }\n    ];\n    break;\n\n  case \"confirmacao_presenca_2\":\n    // usa {{1}} → evento\n    parameters = [\n      { type: \"text\", text: String(entrada.var_2) }\n    ];\n    break;\n\n  case \"confirmacao_presenca_3\":\n    // usa {{1}} → evento\n    parameters = [\n      { type: \"text\", text: String(entrada.var_2) }\n    ];\n    break;\n\n  case \"confirmacao_inscricao_chat_1\":\n  case \"confirmacao_inscricao_chat_2\":\n    // usa {{1}} nome, {{2}} evento, {{3}} link\n    parameters = [\n      { type: \"text\", text: String(entrada.var_1) },\n      { type: \"text\", text: String(entrada.var_2) },\n      { type: \"text\", text: String(entrada.var_3) }\n    ];\n    break;\n}\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefone),\n  type: \"template\",\n  template: {\n    name: entrada.template,\n    language: { code: \"pt_BR\" },\n    components: [\n      {\n        type: \"body\",\n        parameters\n      }\n    ]\n  }\n};\n\nreturn [{ json: { resultado: body } }];\n"
      },
