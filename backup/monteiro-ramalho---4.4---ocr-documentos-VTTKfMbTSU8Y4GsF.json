    {
      "parameters": {
        "jsCode": "let texto = $json.extractedText ?? $json.text ?? \"\";\n\nif (Array.isArray(texto)) {\n  texto = texto.join(\"\\n\");\n}\n\ntexto = String(texto);\n\nreturn [\n  {\n    json: {\n      texto\n    }\n  }\n];"
      },
