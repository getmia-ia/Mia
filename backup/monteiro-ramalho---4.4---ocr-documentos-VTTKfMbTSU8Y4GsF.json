      ],
      "id": "a143f39e-84f1-420f-891e-66bfe986ceb9",
      "name": "Extract text",
      "retryOnFail": true,
      "waitBetweenTries": 5000,
      "credentials": {
        "mistralCloudApi": {
          "id": "V81QQS8om3rLYwbV",
