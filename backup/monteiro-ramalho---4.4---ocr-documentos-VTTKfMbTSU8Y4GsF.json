        "httpBearerAuth": "***REMOVIDO***"
      }
    },
    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  const conversionUrl = item.json.conversionUrl || \"\";\n\n  const urls = conversionUrl\n    .split(\",\")\n    .map(url => url.trim())\n    .filter(url => url.length > 0);\n\n  urls.forEach((url, index) => {\n    output.push({\n      json: {\n        defensaId: item.json.defensaId,\n        templateGoogleDocId: item.json.templateGoogleDocId,\n        pageIndex: index,\n        totalPages: urls.length,\n        url: url\n      }\n    });\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
        -784
      ],
      "id": "0a300694-f737-441f-8c44-295003da216e",
      "name": "Split das pgs convertidas",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1184,
        -768
      ],
      "id": "e4a8f26e-d18b-483d-9bdf-b69dd99a5ef9",
      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "amount": 2
      },
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        1568,
        -752
      ],
      "id": "ebf48b35-5b92-4387-8769-63ff4411e933",
      "name": "Wait",
      "webhookId": "1a1d768a-49b7-4352-8fbb-ec83d58828ef"
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        736,
        176
      ],
      "id": "839476d2-65d2-4796-af75-198dce1fcd7c",
      "name": "Merge1"
    },
    {
      "parameters": {
        "jsCode": "const RANGE_SIZE = 3;\n\nconst output = [];\n\nfor (const item of items) {\n\n  const pdf = item.json;\n\n  const totalPages = pdf.numpages || 1;\n\n  for (let page = 1; page <= totalPages; page += RANGE_SIZE) {\n\n    const pageFrom = page;\n\n    const pageTo = Math.min(\n      page + RANGE_SIZE - 1,\n      totalPages\n    );\n\n    output.push({\n      json: {\n\n        // URL correta\n        url: pdf.body.document_url,\n\n        // info do chunk\n        totalPages,\n        page_from: pageFrom,\n        page_to: pageTo,\n\n        // identificador útil\n        chunk_id: `${pdf.midiaIndex}_${pageFrom}_${pageTo}`,\n\n        // opcional\n        is_last_chunk: pageTo === totalPages\n      }\n    });\n\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        -768
      ],
      "id": "2cce63c7-2c06-4a10-8ab3-320cc8cc36b2",
      "name": "Range de pgs"
    },
    {
      "parameters": {
        "url": "={{ $json.body.url }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        208,
        -64
      ],
      "id": "c3dabf10-39ab-4baa-880c-e25b754a09a9",
      "name": "Baixar arquivo",
      "retryOnFail": false,
      "maxTries": 5,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const pages = [];\n\n// percorre todos os itens\nfor (const item of items) {\n\n  // alguns outputs vêm como array dentro do json\n  const data = Array.isArray(item.json)\n    ? item.json\n    : [item.json];\n\n  for (const msg of data) {\n\n    // pega o texto do OCR\n    const text = msg?.content?.[0]?.text || '';\n\n    // remove markdown ```txt\n    const cleaned = text\n      .replace(/```txt/g, '')\n      .replace(/```/g, '')\n      .trim();\n\n    pages.push(cleaned);\n  }\n}\n\n// junta tudo\nconst fullDocument = pages.join('\\n\\n');\n\n// retorna um único item\nreturn [\n  {\n    json: {\n      document: fullDocument\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
