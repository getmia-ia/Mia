        "jsCode": "// Function Node - Versão simplificada\nconst caption = $('X parametros').item.json.x_post_caption;\n\nconst payload = {\n  text: caption,\n  media: {\n    media_ids: [\n      $('Sobe img 1 no X').item.json.media_id_string\n    ].filter(id => id) // Remove valores null/undefined\n  }\n};\n\n// Validação básica\nif (!payload.text) throw new Error('Texto é obrigatório');\nif (payload.media.media_ids.length === 0) throw new Error('Mídias são obrigatórias');\n\nreturn payload;"
