    {
      "parameters": {
        "content": "### 1. TRATAMENTO DE DADOS E FILA\nAqui o banco decide quem entra na fila e limpa os telefones.",
        "height": 280,
        "width": 560,
        "color": 6
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -3584,
        6272
      ],
      "id": "adfd099f-a1ee-4b7e-8ea3-f1f71577b1dd",
      "name": "Sticky Note7",
      "disabled": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"public\".renovacao_anuncios \n    (user_id, bid_id, nome_produto, email, telefone, tipo, sent, expire, created_at, ultimo_anuncio)\nSELECT DISTINCT ON (b.creator_id) \n    b.creator_id,\n    b.id,\n    p.name,\n    u.email,\n    f.telefone_limpo,\n    CASE \n        WHEN b.status_id IN (2, 3) THEN 'expirado'          -- Retirado + Expirado (canônico)\n        WHEN b.status_id = 1\n             AND b.created <= now()::timestamp - interval '8 days'\n          THEN '8dias'\n        ELSE 'ativo'                                         -- status_id = 1, recente\n    END AS tipo,\n    false AS sent, \n    b.expire,\n    b.created,\n    b.created AS ultimo_anuncio\nFROM an_prod_cbc.bids b\nLEFT JOIN an_prod_types.products p ON p.id = b.product_id\nLEFT JOIN an_prod_cbc.users u ON u.id = b.creator_id\nLEFT JOIN an_prod_cbc.user_profiles up ON up.user_id = u.id\nLEFT JOIN an_prod_cbc.profile_phones pp ON pp.profile_id = up.id\nLEFT JOIN an_prod_cbc.phones phones ON phones.id = pp.phone_id\nCROSS JOIN LATERAL (\n    SELECT \n        CASE \n            WHEN ltrim(regexp_replace(phones.number, '\\D', '', 'g'), '0') LIKE '55%' \n                THEN ltrim(regexp_replace(phones.number, '\\D', '', 'g'), '0') \n            ELSE '55' || ltrim(regexp_replace(phones.number, '\\D', '', 'g'), '0') \n        END AS telefone_limpo\n) f\nWHERE b.deleted = false \n  AND b.created >= '2022-01-01' \n  AND phones.number IS NOT NULL \n  AND length(f.telefone_limpo) >= 10 \nORDER BY b.creator_id, b.created DESC, phones.id DESC\nON CONFLICT (user_id) \nDO UPDATE SET\n    bid_id          = EXCLUDED.bid_id,\n    nome_produto    = EXCLUDED.nome_produto,\n    telefone        = EXCLUDED.telefone,\n    tipo            = EXCLUDED.tipo,\n    expire          = EXCLUDED.expire,\n    created_at      = EXCLUDED.created_at,\n    ultimo_anuncio  = EXCLUDED.created_at,\n    sent = CASE \n                WHEN \"public\".renovacao_anuncios.created_at != EXCLUDED.created_at \n                  OR EXCLUDED.tipo = 'ativo'\n                THEN false \n                ELSE \"public\".renovacao_anuncios.sent \n           END,\n    sent_at = CASE \n                WHEN \"public\".renovacao_anuncios.created_at != EXCLUDED.created_at\n                  OR EXCLUDED.tipo = 'ativo'\n                THEN NULL \n                ELSE \"public\".renovacao_anuncios.sent_at \n              END;",
        "options": {}
      },
