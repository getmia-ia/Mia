    {
      "parameters": {
        "jsCode": "const entrada = items[0].json;\n\n// Sanitiza os campos\nconst nome = String(entrada.nome || \"\").replace(/\\s+/g, \" \").trim();\nconst empresa = String(entrada.empresa || \"sua empresa\").replace(/\\s+/g, \" \").trim();\nconst segmento = String(entrada.segmento || \"seu setor\").replace(/\\s+/g, \" \").trim();\n\n// Preview da mensagem (para memória e auditoria)\nconst mensagemCompleta = `Olá, ${nome}! Boa tarde!\n\nAqui é Monteiro, diretor da BMS Consultoria Tributária.\n\nEstou entrando em contato porque a BMS atende empresas do setor ${segmento} e atua identificando impostos pagos a maior na folha de pagamento e na área fiscal, sempre de forma segura e com respaldo jurídico sólido.\n\nFizemos uma análise preliminar do perfil da ${empresa} e acreditamos que pode existir uma oportunidade concreta de recuperação de créditos tributários relacionada a atualizações legislativas recentes.\n\nPrefiro não entrar em muitos detalhes por aqui para não tomar seu tempo. Gostaria de propor uma conversa rápida de aproximadamente 10 minutos para apresentar o que identificamos e explicar quais oportunidades podem existir para a empresa.\n\nQual seria o melhor dia para conversarmos nesta ou na próxima semana?`;\n\n// Memória Redis\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagemCompleta,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\n// Payload do WhatsApp\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefone),\n  type: \"template\",\n  template: {\n    name: \"appointment\", // <-- substituir pelo nome real do template\n    language: {\n      code: \"pt_BR\"\n    },\n    components: [\n      {\n        type: \"body\",\n        parameters: [\n          {\n            type: \"text\",\n            text: nome\n          },\n          {\n            type: \"text\",\n            text: segmento\n          },\n          {\n            type: \"text\",\n            text: empresa\n          }\n        ]\n      }\n    ]\n  }\n};\n\nreturn [{\n  json: {\n    participant_id: entrada.id,\n    telefone: entrada.telefone,\n    nome,\n    empresa,\n    segmento,\n\n    template_name: \"disparo_inicial_bms\",\n\n    // Preview da mensagem\n    mensagem_completa: mensagemCompleta,\n\n    // Compatível com Redis Chat Memory\n    redis_memory_message: redisMemoryMessage,\n\n    // Body para enviar ao WhatsApp\n    resultado: body\n  }\n}];"
      },
