      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  const original = item.json;\n\n  // 🔤 Normalizar nome\n  const normalizeName = (str) => {\n    return str\n      .normalize(\"NFD\")\n      .replace(/[\\u0300-\\u036f]/g, \"\")\n      .toLowerCase()\n      .replace(/[^a-z0-9.\\-]+/g, \"-\")\n      .replace(/-{2,}/g, \"---\")\n      .replace(/^-+|-+$/g, \"\");\n  };\n\n  // 🔐 Sanitização pesada\n  const sanitizeSensitiveData = (obj) => {\n    const SENSITIVE_KEYS = [\n      \"apiKey\", \"apikey\", \"api_key\",\n      \"token\", \"access_token\", \"refresh_token\",\n      \"authorization\", \"auth\",\n      \"client_secret\", \"secret\",\n      \"password\", \"pass\",\n      \"x-api-key\",\n      \"headers\"\n    ];\n\n    const SENSITIVE_PATTERNS = [\n      /sk-[a-zA-Z0-9_\\-]{10,}/g,\n      /Bearer\\s+[a-zA-Z0-9\\-\\._~\\+\\/]+=*/gi,\n      /AIza[0-9A-Za-z\\-_]{35}/g,\n      /ghp_[a-zA-Z0-9]{36}/g,\n      /xox[baprs]-[a-zA-Z0-9\\-]{10,}/g,\n      /eyJ[a-zA-Z0-9_\\-]+?\\.[a-zA-Z0-9_\\-]+?\\.[a-zA-Z0-9_\\-]+/g\n    ];\n\n    const walk = (value) => {\n      if (Array.isArray(value)) {\n        return value.map(walk);\n      }\n\n      if (value && typeof value === \"object\") {\n        return Object.fromEntries(\n          Object.entries(value).map(([key, val]) => {\n            const lowerKey = key.toLowerCase();\n\n            // 🔥 Remove campos sensíveis inteiros\n            if (SENSITIVE_KEYS.some(k => lowerKey.includes(k))) {\n              return [key, \"***REMOVIDO***\"];\n            }\n\n            return [key, walk(val)];\n          })\n        );\n      }\n\n      if (typeof value === \"string\") {\n        let sanitized = value;\n\n        SENSITIVE_PATTERNS.forEach(pattern => {\n          sanitized = sanitized.replace(pattern, \"***REMOVIDO***\");\n        });\n\n        return sanitized;\n      }\n\n      return value;\n    };\n\n    return walk(obj);\n  };\n\n  // 📄 Monta conteúdo base\n  let contentObject = {\n    updatedAt: original.updatedAt,\n    createdAt: original.createdAt,\n    id: original.id,\n    name: original.name,\n    active: original.active,\n    isArchived: original.isArchived,\n    nodes: original.nodes,\n    connections: original.connections,\n    settings: original.settings,\n    staticData: original.staticData,\n    meta: original.meta,\n    versionId: original.versionId,\n    activeVersionId: original.activeVersionId,\n    triggerCount: original.triggerCount,\n    shared: original.shared,\n    activeVersion: original.activeVersion,\n    tags: original.tags\n  };\n\n  // ❌ REMOVE completamente dados perigosos\n  delete contentObject.pinData;\n\n  // 🔐 Sanitiza tudo\n  contentObject = sanitizeSensitiveData(contentObject);\n\n  const cleanName = normalizeName(original.name || \"workflow\");\n\n  return {\n    json: {\n      ...original,\n\n      // nome tratado\n      name_clean: cleanName,\n\n      // nome do arquivo\n      fileName: `${cleanName}-${original.id}.json`,\n\n      // conteúdo seguro\n      content: JSON.stringify(contentObject, null, 2)\n    }\n  };\n});"
        },
        "type": "n8n-nodes-base.code",
