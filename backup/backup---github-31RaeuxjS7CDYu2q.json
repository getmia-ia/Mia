} catch {\n    base64 = Buffer.from(\"{\\\"error\\\":\\\"base64_fail\\\"}\").toString(\"base64\");\n  }\n\n  // 🔥 6. LIMITE DE TAMANHO (evita erro silencioso do GitHub)\n  const MAX_SIZE = 500000; // ~500KB\n  if (base64.length > MAX_SIZE) {\n    base64 = Buffer.from(\n      JSON.stringify({ error: \"payload_muito_grande\" })\n    ).toString(\"base64\");\n  }\n\n  return {\n    json: {\n      ...safeJson,\n      name_clean: cleanName,\n      fileName: `${cleanName}-${safeId}.json`,\n      content_base64: base64\n    }\n  };\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-224,336],"id":"1b1ae564-3daa-4d0a-90db-13507dae3e03","name":"Code in JavaScript"}],"connections":{"Seta data":{"main":[[{"node":"Formata a data","type":"main","index":0}]]},"Formata a data":{"main":[[{"node":"Seta a data de commit","type":"main","index":0}]]},"Recupera Workflows - N8N":{"main":[[{"node":"Code in JavaScript","type":"main","index":0}]]},"Converte JSON para Binário":{"main":[[]]},"Verifica se o arquivo existe no repositório":{"main":[[{"node":"Atualiza arquivo - GitHub","type":"main","index":0}],[{"node":"Cria/Sobe arquivo - GitHub","type":"main","index":0}]]},"Atualiza arquivo - GitHub":{"main":[[{"node":"Wait","type":"main","index":0}]]},"Cria/Sobe arquivo - GitHub":{"main":[[{"node":"Wait1","type":"main","index":0}],[{"node":"Enviar texto","type":"main","index":0}]]},"Combinar nomes de arquivos - GitHub":{"main":[[{"node":"Recupera Workflows - N8N","type":"main","index":0}]]},"Loop Over Items":{"main":[[],[{"node":"Verifica se o arquivo existe no repositório","type":"main","index":0}]]},"Lista de Arquivos":{"main":[[{"node":"Combinar nomes de arquivos - GitHub","type":"main","index":0}]]},"Seta a data de commit":{"main":[[{"node":"Lista de Arquivos","type":"main","index":0}]]},"Wait":{"main":[[{"node":"Loop Over Items","type":"main","index":0}]]},"Wait1":{"main":[[{"node":"Loop Over Items","type":"main","index":0}]]},"Schedule Trigger":{"main":[[{"node":"Seta data",