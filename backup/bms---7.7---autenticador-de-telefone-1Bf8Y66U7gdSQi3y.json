    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DECLARE @phone_raw VARCHAR(20) = '{{ $('Edit Fields').item.json.phone }}';\n\n-- Normaliza o telefone recebido\nDECLARE @phone VARCHAR(20) =\n    REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(@phone_raw,\n    '(', ''), ')', ''), '-', ''), ' ', ''), '+', '');\n\n-- Remove o código do país (55), se existir\nIF LEFT(@phone, 2) = '55'\n    SET @phone = SUBSTRING(@phone, 3, LEN(@phone));\n\n-- Últimos 8 dígitos\nDECLARE @phone_suffix VARCHAR(8) = RIGHT(@phone, 8);\n\nSELECT TOP (1)\n    e.id_employee,\n    u.id_user,\n    u.name,\n    u.email,\n    COALESCE(u.phone, e.phone) AS telefone\nFROM employee e\nINNER JOIN [user] u\n    ON u.id_user = e.user_id\n\nCROSS APPLY (\n    SELECT\n        phone_user = RIGHT(\n            REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(ISNULL(u.phone,''), '(', ''), ')', ''), '-', ''), ' ', ''), '+', ''),\n            8\n        ),\n        phone_employee = RIGHT(\n            REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(ISNULL(e.phone,''), '(', ''), ')', ''), '-', ''), ' ', ''), '+', ''),\n            8\n        )\n) p\n\nWHERE\n    e.[delete] = 'N'\n    AND (\n        p.phone_user = @phone_suffix\n        OR\n        p.phone_employee = @phone_suffix\n    );"
      },
