              "name": "telefone",
              "value": "={{\n(raw => {\n  let t = (raw || \"\")\n    .toString()\n    .replace(/\\D/g, \"\"); // remove tudo que não é número\n\n  // remove DDI se já vier\n  if (t.startsWith(\"55\") && t.length > 11) {\n    t = t.slice(2);\n  }\n\n  // se tiver 10 dígitos (DDD + 8), adiciona 9\n  if (t.length === 10) {\n    t = t.slice(0, 2) + \"9\" + t.slice(2);\n  }\n\n  // se tiver 11 dígitos (DDD + 9 + 8), mantém\n  if (t.length === 11) {\n    t = \"55\" + t;\n  }\n\n  return t;\n})($json.whatsapp)\n}}",
