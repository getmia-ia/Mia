      "id": "019ec08a-a1de-4ad8-96ba-bad22ea7416c",
      "name": "Ignorar Instancias",
      "executeOnce": true
    },
    {
      "parameters": {
        "jsCode": "// Pega ignoreNames do node \"Ignorar Instancias\" (pode não existir)\nlet IGNORE = $('Ignorar Instancias').first()?.json?.ignoreNames;\n\n// Normaliza IGNORE para array de strings\nif (typeof IGNORE === 'string') {\n  const s = IGNORE.trim();\n\n  if (s.startsWith('[') && s.endsWith(']')) {\n    try { IGNORE = JSON.parse(s); } catch { IGNORE = [s]; }\n  } else {\n    IGNORE = s.split(',').map(x => x.trim()).filter(Boolean);\n  }\n} else if (!Array.isArray(IGNORE)) {\n  IGNORE = IGNORE ? [IGNORE] : [];\n}\n\n// Se for array de objetos, extrai \"name\"\nIGNORE = IGNORE.map(v => {\n  if (v && typeof v === 'object') return v.name ?? String(v);\n  return String(v);\n}).map(s => s.trim()).filter(Boolean);\n\nconst ignoreSet = new Set(IGNORE.map(s => s.toLowerCase()));\n\n// ✅ body já é array de objetos\nconst instances = $('HTTP Request').first()?.json?.body || [];\n\nconst names = instances\n  .filter(x => x?.name)\n  .filter(x => !ignoreSet.has(String(x.name).trim().toLowerCase()))\n  .filter(x => String(x.connectionStatus || '').toLowerCase() !== 'open')\n  .map(x => x.name);\n\n// Se não tiver nenhuma desconectada, não retorna nada\nif (names.length === 0) return [];\n\nreturn [{\n  instances: names.join(', '),\n  instancesList: names,\n  unconnectedInstances: names.length,\n  ignored: IGNORE, // deixe por enquanto pra validar; depois pode remover\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -432,
        -448
      ],
      "id": "bd738749-0d21-4489-be27-96bdb6f8712e",
      "name": "Lista Instancias OFF"
    },
    {
