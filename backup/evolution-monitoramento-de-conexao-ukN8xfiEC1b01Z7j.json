              "value": "[5511954187344]",
              "type": "array"
            },
            {
              "id": "5116cc4f-1074-4d10-a3d8-7c56754f6e37",
              "name": "Mensagem",
              "value": "={{ $('HTTP Request').item.json.statusCode === 200\n  ? `⚠️ EVOLUTION API\\n>> ${$('Lista Instancias OFF').item.json.instances} OFF(`+$json.unconnectedInstances+`)`\n  : `⚠️⚠️⚠️ EVOLUTION API\\n>> ATENÇÃO - SERVIDOR OFF`\n}}",
              "type": "string"
            }
