    {
      "parameters": {
        "jsCode": "function ajustarTelefone(raw) {\n  if (!raw) return null;\n\n  let t = raw.toString();\n\n  // Remove tudo que não é número\n  t = t.replace(/\\D/g, \"\");\n\n  // Se vier com 11 dígitos (celular padrão)\n  if (t.length === 11) {\n    t = \"55\" + t;\n  }\n\n  // Se vier com 10 dígitos (fixo)\n  if (t.length === 10) {\n    t = \"55\" + t;\n  }\n\n  // Se já vier com 55 no início, deixa assim\n  if (t.startsWith(\"55\")) {\n    return t;\n  }\n\n  // Se vier com +55, remove o +\n  if (t.startsWith(\"+\")) {\n    t = t.replace(\"+\", \"\");\n    return t;\n  }\n\n  return t;\n}\n\n// Usa UTC diretamente\nconst agora = Date.now();\n\n// Define janelas de lembrete (em minutos)\nconst janelas = [\n  { tipo: \"10min\", inicio: 7, fim: 12 },\n  { tipo: \"2min\", inicio: 1, fim: 3 },\n];\n\nconst filtrados = [];\n\nfor (const item of items) {\n  const lead = item.json;\n  const telefone = lead.property_contato ?? null;\n  const reuniao = lead.property_data_de_reuni_o?.start;\n  if (!reuniao) continue;\n\n  // Notion envia ISO com timezone → JS converte automaticamente pra UTC\n  const timestampReuniao = new Date(reuniao).getTime();\n\n  // Verifica se a reunião está dentro de alguma das janelas definidas\n  for (const janela of janelas) {\n    const minInicio = agora + janela.inicio * 60 * 1000;\n    const minFim = agora + janela.fim * 60 * 1000;\n\n    if (timestampReuniao >= minInicio && timestampReuniao <= minFim) {\n      filtrados.push({\n        json: {\n          ...lead,\n          telefonePadronizado: ajustarTelefone(telefone),\n          timestampReuniao,\n          agoraUTC: agora,\n          tipoLembrete: janela.tipo, // Identifica se é 10min ou 2min\n        },\n      });\n    }\n  }\n}\n\nreturn filtrados;\n"
      },
