    {
      "parameters": {
        "jsCode": "// ==========================\n// DEFINIÇÃO DOS TEMPLATES\n// ==========================\n\n// templates para 10 minutos\nconst templates10 = {\n  reminder_reuniao_sem_link: {\n    name: \"reminder_reuniao_sem_link\",\n    vars: 1,\n    text: \"Oi, {{1}}!\\nNossa reunião começa em aproximadamente *10 minutos*.\\nAté já!\"\n  },\n  reminder_reuniao: {\n    name: \"reminder_reuniao\",\n    vars: 2,\n    text: \"Oi, {{1}}!\\nSua reunião começa em aproximadamente *10 minutos*.\\n\\nAqui está o link: {{2}}\\n\\nAté já!\"\n  }\n};\n\n// templates para 2 minutos\nconst templates2 = {\n  reminder_reuniao_sem_link: {\n    name: \"reminder_reuniao_sem_link_2min\",\n    vars: 1,\n    text: \"Oi, {{1}}!\\nSua reunião começa em *2 minutos*.\\nAté já!\"\n  },\n  reminder_reuniao: {\n    name: \"reminder_reuniao_2min\",\n    vars: 2,\n    text: \"Oi, {{1}}!\\nSua reunião começa em *2 minutos*.\\n\\nAqui está o link: {{2}}\\n\\nBora lá!\"\n  }\n};\n\n// ==========================\n// PROCESSADOR PRINCIPAL\n// ==========================\nconst entrada = items[0].json;\n\n// Extrai link (Meet / Zoom)\nconst linkReuniao =\n  entrada?.conferenceData?.entryPoints?.[0]?.uri || null;\n\n// Tipo de lembrete vindo do nó anterior\nconst tipoLembrete = $('Prepara e seleciona os dados dos leads que tem reunião nos proximos 10min').first().json.tipoLembrete || \"10min\";\n\n// Escolhe o conjunto de templates conforme o tipo\nconst templates = tipoLembrete === \"2min\" ? templates2 : templates10;\n\n// Escolha do template conforme presença do link\nconst templateEscolhido = linkReuniao\n  ? templates.reminder_reuniao\n  : templates.reminder_reuniao_sem_link;\n\n// ==========================\n// MONTAGEM DO BODY DO WHATSAPP\n// ==========================\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String($('Preparar variáveis do lead').first().json.telefone || \"\"),\n  type: \"template\",\n  template: {\n    name: templateEscolhido.name,\n    language: { code: \"pt_BR\" },\n    components: []\n  }\n};\n\n// ==========================\n// VARIÁVEIS DO TEMPLATE\n// ==========================\nconst parameters = [];\n\n// Nome\nif (templateEscolhido.vars >= 1) {\n  parameters.push({ type: \"text\", text: $('Preparar variáveis do lead').first().json.name || \"\" });\n}\n\n// Link (se existir)\nif (templateEscolhido.vars >= 2) {\n  parameters.push({ type: \"text\", text: linkReuniao || \"\" });\n}\n\nbody.template.components.push({\n  type: \"body\",\n  parameters\n});\n\n// ==========================\n// TEXTO FINAL PARA HISTÓRICO\n// ==========================\nconst textoFinal = templateEscolhido.text\n  .replace(\"{{1}}\", $('Preparar variáveis do lead').first().json.name || \"\")\n  .replace(\"{{2}}\", linkReuniao || \"\");\n\n// ==========================\n// RETORNO — FORMATO PERFEITO\n// ==========================\nreturn {\n  json: {\n    resultado: body,\n    mensagem_final: textoFinal,\n    template_usado: templateEscolhido.name,\n    tipoLembrete\n  }\n};\n"
      },
