              "value": "={{ $json.body.lead_data.full_name }}",
              "type": "string"
            },
            {
              "id": "a3d70d7b-7897-44f1-8d3a-ebc1551da964",
              "name": "Contato",
              "value": "={{\n(raw => {\n  let t = (raw || \"\").toString().replace(/\\s+/g, \"\").replace(/\\D/g, \"\");\n  t = t.replace(/^0+/, \"\");\n  if (t.length === 8) {\n    t = \"11\" + \"9\" + t;\n  } else if (t.length === 9) {\n    t = \"11\" + t;\n  } else if (t.length === 10) {\n    t = t.replace(/^(\\d{2})(\\d{8})$/, \"$19$2\");\n  } else if (t.length === 11) {\n    t = \"55\" + t;\n  } else if (t.length === 12) {\n    t = t.slice(0, 4) + \"9\" + t.slice(4);\n  } else if (t.length > 13) {\n    t = t.slice(-13);\n  }\n  return t;\n})($('Webhook').item.json.body.lead_data.phone)\n}}",
              "type": "string"
            },
            {
              "id": "8c323ed9-f71d-4d83-88af-1a0d6a57850f",
              "name": "E-mail",
              "value": "={{ $json.body.lead_data.email }}",
              "type": "string"
            },
            {
              "id": "5c1e2e2e-22f1-47d2-995b-a9f1822e3369",
