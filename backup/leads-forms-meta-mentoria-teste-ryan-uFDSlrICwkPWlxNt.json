              "type": "string"
            },
            {
              "id": "08076660-8d6d-4a49-96bd-d56541a58bbd",
              "name": "Produto",
              "value": "={{ \n  (() => {\n    const tag = $json.body.campaign.campaign_name\n      .match(/\\[(.*?)\\]/g)?.[1]\n      ?.replace(/[\\[\\]]/g, '')\n      ?.toLowerCase() || '';\n\n    return tag.charAt(0).toUpperCase() + tag.slice(1);\n  })()\n}}",
