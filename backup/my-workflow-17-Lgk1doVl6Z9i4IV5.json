    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.body.imageBase64;\n\n// Remove o prefixo data:...;base64,\nconst base64Clean = raw.includes(',') ? raw.split(',')[1] : raw;\nconst mimeType = raw.startsWith('data:') \n  ? raw.split(';')[0].replace('data:', '') \n  : 'image/jpeg';\n\nreturn [{\n  json: {\n    body: {\n      model: \"claude-opus-4-5-20251101\",\n      max_tokens: 4096,\n      messages: [{\n        role: \"user\",\n        content: [\n          {\n            type: \"image\",\n            source: {\n              type: \"base64\",\n              media_type: mimeType,\n              data: base64Clean\n            }\n          },\n          {\n            type: \"text\",\n            text: \"Analise este criativo de marketing e converta em HTML+CSS fiel. Use variáveis CSS (:root) para preço, textos e cores. Retorne apenas o código HTML completo.\"\n          }\n        ]\n      }]\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
