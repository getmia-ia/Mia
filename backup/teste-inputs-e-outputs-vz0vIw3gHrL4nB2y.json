    {
      "parameters": {
        "jsCode": "// 1. Obtém todos os itens de entrada do nó anterior\nconst items = $input.all();\n\n// --- CONFIGURAÇÃO ---\n// Substitua 'lista_cnpjs' pelo nome exato da propriedade que vem do seu JSON\nconst nomeDoCampo = 'lista_cnpjs';\n// --------------------\n\nlet resultado = null;\n\n// 2. Verifica se recebemos algum dado\nif (items.length > 0) {\n  // Acessa os dados do primeiro item (geralmente onde a lista reside)\n  const dados = items[0].json;\n\n  // 3. Verifica se o campo existe e se é uma lista (Array)\n  if (dados[nomeDoCampo] && Array.isArray(dados[nomeDoCampo])) {\n    const lista = dados[nomeDoCampo];\n\n    // 4. Se a lista não estiver vazia, pega o primeiro elemento (índice 0)\n    if (lista.length > 0) {\n      resultado = lista[0];\n    }\n  }\n}\n\n// 5. Retorna o dado formatado para o próximo nó\nreturn [\n  {\n    json: {\n      primeiro_cnpj: resultado || \"Nenhum CNPJ encontrado\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
