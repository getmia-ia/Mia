      "name": "Checa envio de midia",
      "executeOnce": true,
      "alwaysOutputData": true,
      "onError": "continueRegularOutput",
      "notes": "Este fluxo é de propriedade da FORMAÇÃO AGENTES DE IA COM N8N -BY RICNEVES"
    },
    {
      "parameters": {
        "jsCode": "// ===============================\n// CONFIG\n// ===============================\n\nconst LIMITE_RECENTE = 30;\n\n// ===============================\n// MÍDIA QUE VAI SER ENVIADA\n// ===============================\n\nconst nomeMidiaNova = $('When Executed by Another Workflow').first().json.midia;\n\n// ===============================\n// HISTÓRICO\n// ===============================\n\nconst historico = $input.all().map(item => item.json);\n\n// Ordena do mais recente para o mais antigo\nhistorico.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));\n\n// Pega só as mais recentes\nconst recentes = historico.slice(0, LIMITE_RECENTE);\n\nlet jaEnviouRecentemente = false;\nlet quandoFoiEnviada = null;\n\nfor (const msg of recentes) {\n\n  if (!msg.mensagem_agente) continue;\n\n  let conteudo = msg.mensagem_agente;\n\n  // Se vier como string JSON (ex: \"\\\"https://...\\\"\")\n  try {\n    conteudo = JSON.parse(conteudo);\n  } catch (e) {\n    // não era JSON, segue normal\n  }\n\n  if (typeof conteudo !== \"string\") continue;\n\n  if (conteudo.includes(\"active_storage\")) {\n\n    const urlLimpa = conteudo.replace(/\"/g, \"\").trim();\n\n    const nomeArquivoUrl = decodeURIComponent(\n      urlLimpa.substring(urlLimpa.lastIndexOf(\"/\") + 1)\n    ).trim();\n\n    const nomeMidiaNormalizado = nomeMidiaNova.trim();\n\n    if (nomeArquivoUrl.toLowerCase() === nomeMidiaNormalizado.toLowerCase()) {\n      jaEnviouRecentemente = true;\n      quandoFoiEnviada = msg.created_at;\n      break;\n    }\n  }\n}\n\n\n// ===============================\n// OUTPUT\n// ===============================\n\nreturn [\n  {\n    json: {\n      midiaNova: nomeMidiaNova,\n      jaEnviouRecentemente,\n      quandoFoiEnviada,\n      podeEnviar: !jaEnviouRecentemente\n    }\n  }\n];\n"
      },
