    {
      "parameters": {
        "url": "=https://graph.facebook.com/v21.0/1576288203353612/message_templates?status=APPROVED&limit=100&access_token=EAFaZCg39Nb7cBQOaYH0ZBFmYgpLLjnWYIhZBAiUXHQPn4rNiBPcH37k3BqM8xh77nn3SgU6iYocIJqEURTpCux2BRjYYIj0kcVYehn9GtOOuA9LjE1n5jwK4ZBUGLsJCxddcCZB6QmYZCwmh1pq9Ech5FsDRxLdalqw6Fv6nUKnmwCXUZAcVa5QFicCkMLYUOibowZDZD",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        208,
        0
      ],
      "id": "95652cb4-d77d-42c7-beee-29381b79803f",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "// Node \"Code\" no n8n — cole este código no lugar do \"Loop Over Items\"/\"Function\"\n// Entrada esperada: a resposta do HTTP Request para GET /{WABA_ID}/message_templates\n// (aceita tanto o formato [{ data: [...], paging: {...} }] quanto { data: [...] } direto)\n\nconst items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  const json = item.json;\n  let templates = [];\n\n  if (Array.isArray(json)) {\n    for (const obj of json) {\n      if (obj.data) templates.push(...obj.data);\n    }\n  } else if (json.data) {\n    templates.push(...json.data);\n  } else {\n    templates.push(json);\n  }\n\n  for (const tpl of templates) {\n    const components = tpl.components || [];\n    const header = components.find((c) => c.type === 'HEADER');\n    const body = components.find((c) => c.type === 'BODY');\n    const footer = components.find((c) => c.type === 'FOOTER');\n    const buttons = components.find((c) => c.type === 'BUTTONS');\n\n    output.push({\n      json: {\n        id: tpl.id,\n        name: tpl.name,\n        language: tpl.language,\n        category: tpl.category,\n        sub_category: tpl.sub_category || '',\n        parameter_format: tpl.parameter_format || '',\n        status: tpl.status,\n\n        // colunas legíveis (referência humana)\n        header_format: header ? header.format : '',\n        header_text: header && header.format === 'TEXT' ? header.text || '' : '',\n        header_media_url:\n          header && header.example && header.example.header_handle\n            ? header.example.header_handle[0]\n            : '',\n        body_text: body ? body.text : '',\n        body_example_params: body && body.example ? JSON.stringify(body.example.body_text || []) : '',\n        footer_text: footer ? footer.text : '',\n        buttons_summary: buttons\n          ? buttons.buttons.map((b) => `${b.type}:${b.text || b.phone_number || b.url || ''}`).join(' | ')\n          : '',\n\n        // coluna \"backup\" — o array components exatamente como a Meta retornou.\n        // é isso que você reenvia no POST /{WABA_ID}/message_templates para recriar o template\n        // (junto com name, language, category, parameter_format)\n        components_json: JSON.stringify(components),\n      },\n    });\n  }\n}\n\nreturn output;"
      },
