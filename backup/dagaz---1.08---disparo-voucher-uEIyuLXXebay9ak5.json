        "typeVersion": 1,
        "id": "3caae9e1-d072-4301-b588-ce68d620dbc8",
        "name": "Sticky Note1"
      },
      {
        "parameters": {
          "jsCode": "const allItems = $input.all().map(i => i.json);\n\n// Separa o evento dos participantes\nconst evento = allItems.find(i => i.event_date && i.title);\nconst participantes = allItems.filter(i =>\n  i.phone &&\n  !i.event_date &&\n  !i.title\n);\n\nfunction normalizePhone(phone) {\n  if (!phone) return null;\n  let digits = String(phone).replace(/\\D/g, '');\n  if (digits.length >= 10 && digits.length <= 11) digits = '55' + digits;\n  return digits;\n}\n\n// Retorna 1 item por participante com os dados que precisamos no loop\nreturn participantes.map(participant => {\n  return {\n    json: {\n      participant_id:        participant.id,\n      event_id:              participant.event_id,\n      phone:                 normalizePhone(participant.phone),\n      nome:                  participant.name,\n      status:                participant.status,\n      voucher_data:          participant.voucher_data || {},\n      assigned_message_id:   participant.assigned_message_id,\n      assigned_document_url: participant.assigned_document_url || null,\n      phone_number_id:       $('Webhook2').first().json.body.phone_number_id\n    }\n  };\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2096,
          1184
        ],
        "id": "71555ab9-40a1-4875-92b5-f9854a4f9c20",
        "name": "Prepara 1 item por participante"
      },
      {
        "parameters": {
          "operation": "getAll",
          "tableId": "event_messages",
          "returnAll": true,
          "matchType": "allFilters",
          "filters": {
            "conditions": [
              {
                "keyName": "id",
                "condition": "eq",
                "keyValue": "={{ $('Iterar envio por lead1').item.json.assigned_message_id }}"
              }
            ]
          }
        },
        "type": "n8n-nodes-base.supabase",
        "typeVersion": 1,
        "position": [
          2656,
          1200
        ],
        "id": "7a551e39-ec16-4628-982e-6724585f8ba5",
        "name": "Busca template do participante",
        "credentials": {
          "supabaseApi": {
            "id": "5G36ZI0q9SPv9U25",
            "name": "Dagaz - Supabase"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "// Participante vem do iterador\nconst participant = $('Iterar envio por lead1').item.json;\n\n// Template buscado no Supabase para este participante\nconst template = $input.first().json;\n\nconst voucher = participant.voucher_data || {};\n\n// Monta os parâmetros dinâmicos do template a partir do voucher_data\nconst parameters = (template.variables || []).map((_, index) => {\n  const key = `{{${index + 1}}}`;\n  let value = voucher[key];\n  if (value != null) {\n    value = String(value)\n      .replace(/\\r/g, '')\n      .replace(/\\t/g, ' ')\n      .replace(/ {4,}/g, '   ');\n  } else {\n    value = '';\n  }\n  return value;\n});\n\n// Monta param_0, param_1... para uso no body da requisição\nconst paramObj = {};\nparameters.forEach((val, i) => {\n  paramObj[`param_${i}`] = val;\n});\n\n// Define header_type vindo do template\nconst header_type = template.header_type || 'none';\n\n// URL do documento/imagem vem do participante (assigned_document_url)\nconst imagem_url = participant.assigned_document_url || '';\n\n// Monta a mensagem formatada substituindo placeholders\nfunction montarMensagem(templateStr, params) {\n  if (!templateStr) return '';\n  let msg = templateStr;\n  params.forEach((valor, index) => {\n    const placeholder = new RegExp(`{{\\\\s*${index + 1}\\\\s*}}`, 'g');\n    msg = msg.replace(placeholder, valor ?? '');\n  });\n  return msg;\n}\n\nconst mensagem_completa = montarMensagem(template.message_template, parameters);\n\nreturn [{\n  json: {\n    participant_id:   participant.participant_id,\n    event_id:         participant.event_id,\n    telefone:         participant.phone,\n    nome:             participant.nome,\n    status:           participant.status,\n    phone_number_id:  participant.phone_number_id,\n    template_name:    template.meta_template_name,\n    mensagem:         template.message_template,\n    mensagem_completa,\n    requires_image:   template.requires_image,\n    header_type,\n    imagem_url,\n    total_params:     parameters.length,\n    ...paramObj\n  }\n}];"
        },
