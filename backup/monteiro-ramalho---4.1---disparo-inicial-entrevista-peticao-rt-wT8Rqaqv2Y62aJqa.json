      {
        "parameters": {
          "jsCode": "const item = items[0].json;\n\nfunction getPath(obj, path) {\n  return path.split('.').reduce((acc, key) => (acc == null ? undefined : acc[key]), obj);\n}\n\nconst schemaCampos = {\n  desvio_funcao:  \"vinculo.desvio_funcao\",\n  trabalho_fds:   \"jornada.trabalho_fim_semana\",\n  controle_ponto: \"jornada.controle_ponto\",\n};\n\nconst schemaDocumentos = [\"ctps\", \"trct\", \"extrato_fgts\", \"contracheque\", \"prova_agravante\"];\n\n// pergunta completa, no mesmo estilo do roteiro de entrevista —\n// usada tanto na prévia (WhatsApp) quanto no log/memória\nconst perguntas = {\n  desvio_funcao:     \"Você trabalhava só na função registrada, ou também exercia outra função na prática?\",\n  trabalho_fds:      \"Você trabalhava aos sábados, domingos ou feriados?\",\n  controle_ponto:    \"Você assinava folha de ponto ou batia ponto?\",\n  jornada_detalhada: \"Qual era o seu horário de trabalho — entrada, intervalo e saída?\",\n  ctps:              \"Pode me enviar o PDF da sua Carteira de Trabalho Digital (CTPS)?\",\n  trct:              \"Pode me enviar o Termo de Rescisão (TRCT), se já tiver recebido?\",\n  extrato_fgts:      \"Pode me enviar o Extrato do FGTS (app FGTS ou Caixa Tem)?\",\n  contracheque:      \"Pode me enviar os contracheques dos últimos meses trabalhados?\",\n  prova_agravante:   \"Você tem algum atestado, laudo ou print que comprove o que relatou?\",\n};\n\nconst dados = item.triagem || {};\nconst tiposRecebidos = new Set(item.tipos_documento_recebidos || []);\n\nconst pendentesKeys = [];\n\nfor (const [chave, path] of Object.entries(schemaCampos)) {\n  const valor = getPath(dados, path);\n  if (valor === undefined || valor === null || valor === \"\") {\n    pendentesKeys.push(chave);\n  }\n}\n\nconst horarioReal = getPath(dados, \"jornada.horario_real\");\nconst intervalo = getPath(dados, \"jornada.intervalo\");\nif (!horarioReal || !intervalo) {\n  pendentesKeys.push(\"jornada_detalhada\");\n}\n\nfor (const tipo of schemaDocumentos) {\n  if (!tiposRecebidos.has(tipo)) {\n    pendentesKeys.push(tipo);\n  }\n}\n\nconst nome = item.cliente_nome_completo || item.nome || \"\";\n\n// lista completa (todas as pendências) — só para o Agente de Entrevista\n// reaproveitar depois, na conversa real (essa sim pode ter \\n, é texto livre)\nconst listaPerguntasCompleta = pendentesKeys\n  .map((chave, i) => `${i + 1}) ${perguntas[chave] || chave}`)\n  .join(\"\\n\");\n\n// prévia — só os 4 primeiros, SEM quebra de linha (vai dentro do\n// parâmetro do template do WhatsApp, que não aceita \\n)\nconst LIMITE_PREVIEW = 4;\nconst previewKeys = pendentesKeys.slice(0, LIMITE_PREVIEW);\nconst restantes = pendentesKeys.length - previewKeys.length;\n\nlet previewTexto = previewKeys\n  .map((chave, i) => `${i + 1}) ${perguntas[chave] || chave}`)\n  .join(\" \");\n\nif (restantes > 0) {\n  previewTexto += ` E mais ${restantes} ${restantes === 1 ? \"item\" : \"itens\"}, que te explico ao longo da conversa.`;\n}\n\n// mensagem = EXATAMENTE o que vai no template — sem divergência entre\n// o que o cliente recebe e o que fica registrado no log/memória\nconst mensagemCompleta = pendentesKeys.length\n  ? `Olá, ${nome}! Seu contrato de honorários foi assinado com sucesso. 🎉\\n\\nAgora preciso confirmar mais algumas informações e documentos para dar entrada na sua ação:\\n\\n${previewTexto}\\n\\nPode responder por aqui mesmo, com calma. Vamos conversando um item por vez!`\n  : `Olá, ${nome}! Seu contrato de honorários foi assinado com sucesso. 🎉\\n\\nJá tenho quase tudo que preciso — só vou confirmar alguns detalhes finais com você por aqui.`;\n\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagemCompleta,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(item.telefone),\n  type: \"template\",\n  template: {\n    name: \"contrato_update_entrevista\",\n    language: { code: \"pt_BR\" },\n    components: [\n      {\n        type: \"body\",\n        parameters: [\n          { type: \"text\", text: nome },\n          { type: \"text\", text: pendentesKeys.length ? previewTexto : \"alguns detalhes finais\" },\n        ],\n      },\n    ],\n  },\n};\n\nreturn [{\n  json: {\n    id: item.id,\n    telefone: item.telefone,\n    nome,\n    pendentes: pendentesKeys,\n    lista_perguntas_completa: listaPerguntasCompleta, // pro Agente de Entrevista usar depois\n    mensagem_completa: mensagemCompleta,\n    redis_memory_message: redisMemoryMessage,\n    resultado: body,\n  },\n}];"
        },
