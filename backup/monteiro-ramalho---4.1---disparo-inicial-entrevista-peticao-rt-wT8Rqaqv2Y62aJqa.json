          "query": "SELECT\n  l.id,\n  l.nome,\n  l.telefone,\n  l.cliente_nome_completo,\n  l.triagem,\n  COALESCE(\n    (\n      SELECT json_agg(DISTINCT d.tipo_documento)\n      FROM lead_documentos d\n      WHERE d.lead_id = l.id AND d.tipo_documento IS NOT NULL\n    ),\n    '[]'::json\n  ) AS tipos_documento_recebidos\nFROM leads_crm l\nWHERE l.id = $1;",
