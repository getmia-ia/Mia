    {
      "parameters": {
        "jsCode": "const caption = $('X parametros').item.json.x_post_caption;\n\nconst rawIds = [\n  $('Sobe img no X').item.json.media_id_string\n];\n\nconst mediaIds = [...new Set(\n  rawIds\n    .map(v => (v === null || v === undefined) ? '' : String(v).trim())\n    .filter(v => v.length > 0)\n)];\n\nif (!caption || String(caption).trim().length === 0) {\n  throw new Error('Texto é obrigatório');\n}\n\nif (mediaIds.length === 0) {\n  throw new Error('Mídias são obrigatórias');\n}\n\nif (mediaIds.length > 4) {\n  throw new Error(`A API do X aceita no máximo 4 mídias. Você enviou ${mediaIds.length}.`);\n}\n\n// Formato correto para API v2\nconst payload = {\n  text: String(caption).trim(),\n  media: {\n    media_ids: mediaIds\n  }\n};\n\n// IMPORTANTE: Retorna o payload direto, não em array!\nreturn payload;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        32
      ],
