    {
      "parameters": {
        "jsCode": "// Dados recebidos no webhook\nconst entrada = items[0].json.body;\n\n// Verifica se deve usar template\nconst usarTemplate = entrada.use_template === true;\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefone),\n};\n\nif (usarTemplate) {\n  // --- CASO 1: TEMPLATE (Fora de 24h) ---\n  body.type = \"template\";\n  body.template = {\n    name: entrada.template_name,\n    language: {\n      code: entrada.template_language || \"pt_BR\",\n    },\n  };\n\n  // Inclui os parâmetros do template, se existirem\n  if (Array.isArray(entrada.template_components) && entrada.template_components.length > 0) {\n    body.template.components = entrada.template_components;\n  }\n} else {\n  // --- CASO 2: TEXTO LIVRE (Dentro de 24h) ---\n  body.type = \"text\";\n  body.text = {\n    preview_url: false,\n    body: entrada.mensagem || \"Sem mensagem definida\",\n  };\n}\n\n// Mensagem que será salva no histórico\nconst mensagem = entrada.mensagem || \"\";\n\n// Compatível com Redis Chat Memory\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagem,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {},\n  },\n});\n\nreturn [\n  {\n    json: {\n      resultado: body,\n      use_template: usarTemplate,\n      mensagem_para_historico: mensagem,\n      redis_memory_message: redisMemoryMessage,\n      // ID usado pela Meta para montar a URL da Graph API:\n      // https://graph.facebook.com/v18.0/{phone_number_id}/messages\n      phone_number_id: entrada.phone_number_id,\n      // ID interno (Mia) do número — NÃO usar para chamar a API da Meta\n      whatsapp_number_id: entrada.whatsapp_number_id,\n      outbox_id: entrada.outbox_id,\n      enviado_por: entrada.enviado_por,\n      nome_app: entrada.nome_app,\n      historico_id: entrada.historico_id,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
