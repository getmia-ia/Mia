  "name": "Tools - 16 - Apaga arquivos gerados pela API PDF Converter",
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "executeOnce": false,
        "command": "=#!/bin/bash\n\n# ============================================\n# Cleanup PDFs and temp folders older than 2 days\n# ============================================\n\nPDF_BASE_DIR=\"/n8n_data/pdf\"\nPDF_PAGES_DIR=\"/n8n_data/pdf/pdf_pages\"\n\necho \"Starting cleanup job...\"\necho \"Current date: $(date)\"\n\n# --------------------------------------------\n# Remove PDFs antigos\n# --------------------------------------------\necho \"Cleaning old PDFs...\"\nfind \"$PDF_BASE_DIR\" -maxdepth 1 -type f -name \"*.pdf\" -mtime +2 -print -delete\n\n# --------------------------------------------\n# Remove pastas de páginas convertidas antigas\n# --------------------------------------------\necho \"Cleaning old PDF pages directories...\"\nfind \"$PDF_PAGES_DIR\" -mindepth 1 -maxdepth 1 -type d -mtime +2 -print -exec rm -rf {} \\;\n\necho \"Cleanup finished successfully.\""
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -80,
        0
      ],
      "id": "900d1e69-31db-43a0-b17c-779c8044532e",
      "name": "Cleanup Temp Files"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {}
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -320,
        0
      ],
      "id": "e98fe247-7961-4ebe-9450-720916ca44e9",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Configuração\n// ============================================\n\n// Quantidade máxima de dias permitidos\n// (default: 2 dias)\nconst maxAgeDays = 30;\n\n// ============================================\n// Item atual\n// ============================================\n\nconst item = $input.item.json;\nconst fileKey = item.Key;\nconst lastModifiedRaw = item.LastModified;\n\n// Validação básica\nif (!lastModifiedRaw) {\n  return {\n    json: {\n      ...item,\n      isOld: false,\n      error: 'LastModified não informado',\n      ageInDays: null,\n      cutoffDate: null,\n    },\n  };\n}\n\n// ============================================\n// Datas\n// ============================================\n\n// Data de modificação do arquivo (vem do S3)\nconst lastModifiedDate = new Date(lastModifiedRaw);\n\n// Hoje (UTC-safe)\nconst now = new Date();\n\n// Data limite (hoje - maxAgeDays)\nconst cutoffDate = new Date(now);\ncutoffDate.setDate(now.getDate() - maxAgeDays);\n\n// ============================================\n// Cálculo de idade em dias\n// ============================================\n\nconst diffTimeMs = now.getTime() - lastModifiedDate.getTime();\nconst ageInDays = Math.floor(diffTimeMs / (1000 * 60 * 60 * 24));\n\n// Arquivo é antigo?\nconst isOld = ageInDays > maxAgeDays;\n\n// ============================================\n// Helper para formatar datas\n// ============================================\n\nconst formatDate = (date) => {\n  return date.toISOString().split('T')[0];\n};\n\n// ============================================\n// Retorno\n// ============================================\n\nreturn {\n  json: {\n    ...item,\n    isOld,\n    ageInDays,\n    maxAgeDaysUsed: maxAgeDays,\n    lastModifiedFormatted: formatDate(lastModifiedDate),\n    cutoffDate: formatDate(cutoffDate),\n    fileName: fileKey.split('/').pop(),\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        16
      ],
      "id": "c4b2e430-87e7-4f98-9b26-3901f96e5ab1",
      "name": "Code in JavaScript1"
    },
