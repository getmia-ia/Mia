    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  id,\n  nome,\n  telefone,\n  email,\n  etapa,\n  -- valores atuais (NULL = pendente)\n  cliente_nome_completo,\n  cliente_cpf,\n  cliente_nacionalidade,\n  cliente_estado_civil,\n  cliente_profissao,\n  cliente_endereco,\n  -- flags individuais (true = pendente)\n  (NULLIF(TRIM(cliente_nome_completo), '') IS NULL) AS falta_nome_completo,\n  (NULLIF(TRIM(cliente_cpf),           '') IS NULL) AS falta_cpf,\n  (NULLIF(TRIM(cliente_nacionalidade), '') IS NULL) AS falta_nacionalidade,\n  (NULLIF(TRIM(cliente_estado_civil),  '') IS NULL) AS falta_estado_civil,\n  (NULLIF(TRIM(cliente_profissao),     '') IS NULL) AS falta_profissao,\n  (NULLIF(TRIM(email),                 '') IS NULL) AS falta_email,\n  (NULLIF(TRIM(cliente_endereco),      '') IS NULL) AS falta_endereco,\n  -- arrays consolidados\n  ARRAY_REMOVE(ARRAY[\n    CASE WHEN NULLIF(TRIM(cliente_nome_completo), '') IS NULL THEN 'nome_completo' END,\n    CASE WHEN NULLIF(TRIM(cliente_cpf),           '') IS NULL THEN 'cpf'           END,\n    CASE WHEN NULLIF(TRIM(cliente_nacionalidade), '') IS NULL THEN 'nacionalidade' END,\n    CASE WHEN NULLIF(TRIM(cliente_estado_civil),  '') IS NULL THEN 'estado_civil'  END,\n    CASE WHEN NULLIF(TRIM(cliente_profissao),     '') IS NULL THEN 'profissao'     END,\n    CASE WHEN NULLIF(TRIM(email),                 '') IS NULL THEN 'email'         END,\n    CASE WHEN NULLIF(TRIM(cliente_endereco),      '') IS NULL THEN 'endereco'      END\n  ], NULL) AS campos_pendentes,\n  ARRAY_REMOVE(ARRAY[\n    CASE WHEN NULLIF(TRIM(cliente_nome_completo), '') IS NOT NULL THEN 'nome_completo' END,\n    CASE WHEN NULLIF(TRIM(cliente_cpf),           '') IS NOT NULL THEN 'cpf'           END,\n    CASE WHEN NULLIF(TRIM(cliente_nacionalidade), '') IS NOT NULL THEN 'nacionalidade' END,\n    CASE WHEN NULLIF(TRIM(cliente_estado_civil),  '') IS NOT NULL THEN 'estado_civil'  END,\n    CASE WHEN NULLIF(TRIM(cliente_profissao),     '') IS NOT NULL THEN 'profissao'     END,\n    CASE WHEN NULLIF(TRIM(email),                 '') IS NOT NULL THEN 'email'         END,\n    CASE WHEN NULLIF(TRIM(cliente_endereco),      '') IS NOT NULL THEN 'endereco'      END\n  ], NULL) AS campos_preenchidos\nFROM leads_crm\nWHERE etapa = 'dados_pendentes'\n  AND id = $1;   -- ou: AND telefone = $1\n",
        "options": {
          "queryReplacement": "={{ $json.id }}"
        }
