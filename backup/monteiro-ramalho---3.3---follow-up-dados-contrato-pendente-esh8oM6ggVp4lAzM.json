    {
      "parameters": {
        "jsCode": "const entrada = items[0].json;\n\n// Sanitização\nconst nome = String(entrada.nome || \"\")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\n// Tradução dos nomes dos campos\nconst labels = {\n  nome_completo: \"Nome completo\",\n  cpf: \"CPF\",\n  nacionalidade: \"Nacionalidade\",\n  estado_civil: \"Estado civil\",\n  profissao: \"Profissão\",\n  email: \"E-mail\",\n  endereco: \"Endereço completo\"\n};\n\n// Campos pendentes\nconst camposPendentes = Array.isArray(entrada.campos_pendentes)\n  ? entrada.campos_pendentes\n  : [];\n\n// Ex.: \"RG, CPF e Endereço completo\"\nconst camposFormatados = camposPendentes\n  .map(campo => labels[campo] || campo)\n  .join(\", \");\n\n// Preview da mensagem\nconst mensagemCompleta = `Olá, ${nome}! Tudo bem?\n\nEstamos finalizando a elaboração do seu contrato, porém ainda precisamos das seguintes informações:\n\n📋 ${camposFormatados}\n\nAssim que recebermos esses dados, poderemos gerar e encaminhar o contrato para sua análise e assinatura.\n\nSe tiver qualquer dúvida, estamos à disposição para ajudar.`;\n\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagemCompleta,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\n// Body WhatsApp\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefone),\n  type: \"template\",\n  template: {\n    name: \"followup_dados_contrato_pendente\",\n    language: {\n      code: \"pt_BR\"\n    },\n    components: [\n      {\n        type: \"body\",\n        parameters: [\n          {\n            type: \"text\",\n            text: nome\n          },\n          {\n            type: \"text\",\n            text: camposFormatados\n          }\n        ]\n      }\n    ]\n  }\n};\n\nreturn [{\n  json: {\n    participant_id: entrada.id,\n    telefone: entrada.telefone,\n    nome,\n    template_name: \"followup_dados_contrato_pendente\",\n    campos_pendentes: camposPendentes,\n\n    // Preview\n    mensagem_completa: mensagemCompleta,\n\n    // Valor pronto para gravar no Redis\n    redis_memory_message: redisMemoryMessage,\n\n    // Body WhatsApp\n    resultado: body\n  }\n}];"
      },
