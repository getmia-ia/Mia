      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  let raw = item.json.output || \"\";\n  let cleaned = raw;\n\n  cleaned = cleaned.replace(/```json/gi, \"\");\n  cleaned = cleaned.replace(/```/g, \"\");\n  cleaned = cleaned.trim();\n\n  let respostaIA = {};\n\n  try {\n    respostaIA = JSON.parse(cleaned);\n  } catch (e) {\n    respostaIA = {\n      template: \"recebimento_voucher_1\",\n      var_1: item.json.name || \"\",\n      var_2: item.json.evento || \"\",\n      telefone: item.json.phone || \"\"\n    };\n  }\n\n  const templates = {\n    recebimento_voucher_1: \"Olá *{{1}}*! 👋\\n\\nPassando para confirmar se você recebeu as informações do evento *{{2}}*.\\n\\nPor favor, responda esta mensagem para confirmarmos o recebimento. 😊\\n\\nAtenciosamente,\\nDagaz Eventos.\",\n\n    recebimento_voucher_2: \"Oi *{{1}}*,\\n\\nAinda não identificamos sua confirmação sobre o recebimento das informações do evento *{{2}}*.\\n\\nVocê recebeu os dados enviados? Basta responder esta mensagem! \\n\\nAtenciosamente,\\nDagaz Eventos.\",\n\n    recebimento_voucher_3: \"Oii *{{1}}*,\\n\\nPassando novamente para verificar se chegou tudo certo sobre o evento *{{2}}*.\\n\\nQualquer dúvida, estamos à disposição. Confirme o recebimento respondendo por aqui! ✈️\\n\\nAtenciosamente,\\nDagaz Eventos.\"\n  };\n\n  const templateName = respostaIA.template;\n  const textoTemplate = templates[templateName] || templates.recebimento_voucher_1;\n\n  const mensagemFinal = textoTemplate\n    .replace(\"{{1}}\", respostaIA.var_1)\n    .replace(\"{{2}}\", respostaIA.var_2);\n\n  return {\n    json: {\n      ...respostaIA,\n      mensagem_template: mensagemFinal\n    }\n  };\n});"
        },
