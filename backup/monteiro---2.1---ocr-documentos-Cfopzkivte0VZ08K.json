    {
      "parameters": {
        "jsCode": "const pages = [];\n\n// percorre todos os itens\nfor (const item of items) {\n\n  // alguns outputs vêm como array dentro do json\n  const data = Array.isArray(item.json)\n    ? item.json\n    : [item.json];\n\n  for (const msg of data) {\n\n    // pega o texto do OCR\n    const text = msg?.content?.[0]?.text || '';\n\n    // remove markdown ```txt\n    const cleaned = text\n      .replace(/```txt/g, '')\n      .replace(/```/g, '')\n      .trim();\n\n    pages.push(cleaned);\n  }\n}\n\n// junta tudo\nconst fullDocument = pages.join('\\n\\n');\n\n// retorna um único item\nreturn [\n  {\n    json: {\n      document: fullDocument\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
