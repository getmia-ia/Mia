    {
      "parameters": {
        "jsCode": "const RANGE_SIZE = 3;\n\nconst output = [];\n\nfor (const item of items) {\n\n  const pdf = item.json;\n\n  const totalPages = pdf.numpages || 1;\n\n  for (let page = 1; page <= totalPages; page += RANGE_SIZE) {\n\n    const pageFrom = page;\n\n    const pageTo = Math.min(\n      page + RANGE_SIZE - 1,\n      totalPages\n    );\n\n    output.push({\n      json: {\n\n        // URL correta\n        url: pdf.body.document_url,\n\n        // info do chunk\n        totalPages,\n        page_from: pageFrom,\n        page_to: pageTo,\n\n        // identificador útil\n        chunk_id: `${pdf.midiaIndex}_${pageFrom}_${pageTo}`,\n\n        // opcional\n        is_last_chunk: pageTo === totalPages\n      }\n    });\n\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        -768
      ],
      "id": "516a7861-3670-4d66-96a9-41943f50da20",
      "name": "Range de pgs"
