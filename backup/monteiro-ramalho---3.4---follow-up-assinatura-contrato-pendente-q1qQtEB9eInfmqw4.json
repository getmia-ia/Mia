        "operation": "executeQuery",
        "query": "SELECT \n  l.id,\n  l.nome,\n  l.telefone,\n  l.email,\n  l.etapa,\n  l.tipo,\n  l.area_juridica,\n  l.descricao_problema,\n  l.criado_em,\n  l.atualizado_em,\n  c.id AS contrato_id,\n  c.tipo AS contrato_tipo,\n  c.status AS contrato_status,\n  c.doc_url,\n  c.pdf_url,\n  c.disparo_enviado_em,\n  c.assinado_em\nFROM leads_crm l\nINNER JOIN contratos c ON c.lead_id = l.id\nWHERE l.etapa = 'contrato_enviado'\n  AND c.disparo_enviado_em < NOW() - INTERVAL '24 hours'\nORDER BY c.disparo_enviado_em ASC;",
