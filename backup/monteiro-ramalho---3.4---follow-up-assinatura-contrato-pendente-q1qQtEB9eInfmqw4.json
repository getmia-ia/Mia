    {
      "parameters": {
        "jsCode": "const entrada = items[0].json;\n\n// Sanitiza texto para evitar erro 132018 do WhatsApp\nconst nome = String(entrada.nome || \"\")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\nconst mensagemCompleta = `Olá, ${nome}! Tudo bem?\n\nPassando para lembrar que o contrato referente ao seu atendimento já foi enviado e ainda está aguardando sua assinatura.\n\nAssim que o documento for assinado, poderemos dar continuidade aos próximos passos do seu processo.`;\n\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagemCompleta,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefone),\n  type: \"template\",\n  template: {\n    name: \"followup_assinatura_contrato\",\n    language: {\n      code: \"pt_BR\"\n    },\n    components: [\n      {\n        type: \"body\",\n        parameters: [\n          {\n            type: \"text\",\n            text: nome\n          }\n        ]\n      }\n    ]\n  }\n};\n\nreturn [{\n  json: {\n    participant_id: entrada.id,\n    telefone: entrada.telefone,\n    nome: nome,\n    template_name: \"followup_assinatura_contrato\",\n\n    // Preview da mensagem\n    mensagem_completa: mensagemCompleta,\n\n    // Compatível com Redis Chat Memory\n    redis_memory_message: redisMemoryMessage,\n\n    // Body para enviar ao WhatsApp\n    resultado: body\n  }\n}];"
      },
