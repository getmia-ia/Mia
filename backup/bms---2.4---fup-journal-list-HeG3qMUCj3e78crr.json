    {
      "parameters": {
        "jsCode": "const templateName = \"followup\";\n\nreturn items.map(item => {\n  const data = item.json;\n\n  const nome = data.name;\n  const telefone = data.telefoneAjustado;\n\n  // mensagem final (pra salvar no histórico)\n  const mensagemFinal = `Olá, ${nome}!\n\nVocê ainda deseja receber nossas atualizações sobre o mercado tributário?\n\nResponda com:\nSIM para continuar recebendo  \nSAIR para parar de receber`;\n\n  // body da requisição pra Meta\n  const body = {\n    messaging_product: \"whatsapp\",\n    to: telefone.toString(),\n    type: \"template\",\n    template: {\n      name: templateName,\n      language: {\n        code: \"pt_BR\"\n      },\n      components: [\n        {\n          type: \"body\",\n          parameters: [\n            {\n              type: \"text\",\n              text: nome\n            }\n          ]\n        }\n      ]\n    }\n  };\n\n  return {\n    json: {\n      telefone,\n      nome,\n      body,\n      mensagemFinal\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        816
      ],
      "id": "aec363a2-4b72-4486-a1ad-386c7fb5d4cc",
      "name": "Monta o body de requisição pra Meta"
    },
