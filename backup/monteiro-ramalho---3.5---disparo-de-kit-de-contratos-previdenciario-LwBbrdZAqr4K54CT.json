          "jsCode": "let signerId = null;\n\ntry {\n  // Caso tenha passado pelo nó \"Criar Signatário\"\n  signerId = $('Criar Signatário').first().json.data.id;\n} catch (error) {\n  // Caso o nó não tenha executado, pega do fluxo de signer existente\n  signerId = $('Signer existe?').first().json.signer_id;\n}\n\nreturn [\n  {\n    json: {\n      signer_id: signerId\n    }\n  }\n];"
