      {
        "parameters": {
          "jsCode": "const editFields = $('Edit Fields').first().json;\n\n// Quantidade de documentos do kit vem direto da consulta original ao Supabase,\n// não da contagem de execuções de um node dentro do loop\nconst documentosDoKit = $('Puxa os documentos do kit').all();\nconst totalDocumentos = documentosDoKit.length;\n\n// O link de assinatura continua vindo do primeiro documento processado no loop\nconst execucoesVinculo = $('Vincular Signatário ao Documento').all();\nconst entrada = execucoesVinculo[0].json;\n\nconst nome = String(editFields.nome_cliente || \"\");\nconst link = String(entrada.data.signing_urls[0].url || \"\");\nconst quantidade = String(totalDocumentos);\n\nconst parameters = [\n  { type: \"text\", text: nome },\n  { type: \"text\", text: quantidade },\n  { type: \"text\", text: link }\n];\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(editFields.telefone_cliente),\n  type: \"template\",\n  template: {\n    name: \"contrato_link_2\",\n    language: {\n      code: \"pt_BR\"\n    },\n    components: [\n      {\n        type: \"body\",\n        parameters\n      }\n    ]\n  }\n};\n\nconst mensagem = `Olá, ${nome}. Seus documentos já estão prontos para assinatura digital.\n\nSão ${quantidade} documentos no total. Ao assinar o primeiro, os demais também aparecerão automaticamente para você concluir na mesma sessão.\n\nPara revisar e assinar, acesse o link abaixo:\n\n${link}\n\nCaso tenha qualquer dúvida, estamos à disposição.`;\n\n// Compatível com Redis Chat Memory\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagem,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\nreturn [\n  {\n    json: {\n      body,\n      mensagem,\n      redis_memory_message: redisMemoryMessage\n    }\n  }\n];"
        },
