    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "e1d7bcf9-6cdb-4b3d-a992-bfd5c3ea66d3",
              "name": "weight_unit",
              "value": "={{ \n(() => {\n  const lista = $( \"Listar Unidade Medida\" ).all().map(i => i.json);\n  const unidadeDaIA = $('When Executed by Another Workflow').first().json.unidade;\n  const buscaIA = ( unidadeDaIA || \"\" ).toLowerCase().trim();\n  \n  // 1. Tenta encontrar uma correspondência exata (ex: \"saca\" === \"saca\")\n  let encontrado = lista.find(item => \n    (item.translations?.pt || \"\").toLowerCase() === buscaIA\n  );\n\n  // 2. Se não achar exato, tenta o que começa com a palavra (ex: \"saca\" em \"saca 60kg\")\n  if (!encontrado) {\n    encontrado = lista.find(item => \n      (item.translations?.pt || \"\").toLowerCase().includes(buscaIA)\n    );\n  }\n\n  if (!encontrado) {\n    throw new Error(`Unidade '${unidadeDaIA}' não encontrada.`);\n  }\n\n  return encontrado.id; \n})()\n}}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
