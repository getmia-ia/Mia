    {
      "parameters": {
        "jsCode": "const signersResponse = $input.first().json;\nconst cliente = $('Edit Fields').first().json;\n\nconst emailCliente = (cliente.email_cliente || '').toLowerCase().trim();\n\nconst signerExistente = (signersResponse.data || []).find(\n  signer => (signer.email || '').toLowerCase().trim() === emailCliente\n);\n\nreturn [\n  {\n    json: {\n      signer_exists: !!signerExistente,\n      signer_id: signerExistente?.id || null,\n      signer_email: signerExistente?.email || null,\n      signer_name: signerExistente?.full_name || null,\n    }\n  }\n];"
      },
