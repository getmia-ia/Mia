      {
        "parameters": {
          "jsCode": "const editFields = $('Edit Fields').first().json;\nconst entrada = items[0].json;\n\nconst nome = String(editFields.nome_cliente || \"\");\nconst link = String(entrada.data.signing_urls[0].url || \"\");\n\nconst parameters = [\n  {\n    type: \"text\",\n    text: nome\n  },\n  {\n    type: \"text\",\n    text: link\n  }\n];\n\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(editFields.telefone_cliente),\n  type: \"template\",\n  template: {\n    name: \"contrato_link\",\n    language: {\n      code: \"pt_BR\"\n    },\n    components: [\n      {\n        type: \"body\",\n        parameters\n      }\n    ]\n  }\n};\n\nconst mensagem = `Olá, ${nome}. Seu contrato já está pronto para assinatura digital.\n\nPara revisar e assinar o documento, acesse o link abaixo:\n\n${link}\n\nCaso tenha qualquer dúvida, estamos à disposição.`;\n\n// Compatível com Redis Chat Memory\nconst redisMemoryMessage = JSON.stringify({\n  type: \"ai\",\n  data: {\n    content: mensagem,\n    tool_calls: [],\n    invalid_tool_calls: [],\n    additional_kwargs: {},\n    response_metadata: {}\n  }\n});\n\nreturn [\n  {\n    json: {\n      body,\n      mensagem,\n      redis_memory_message: redisMemoryMessage\n    }\n  }\n];"
        },
