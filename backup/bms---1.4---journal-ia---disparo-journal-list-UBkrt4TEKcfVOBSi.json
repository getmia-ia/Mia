    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1) Buscar dados do Sheets\nconst noticia = $('Encontra a Próxima Notícia Válida').item.json;\nconst legenda = noticia.legenda || '';\nconst param_2 = noticia.param_2 || null;\nconst param_3 = noticia.param_3 || null;\nconst param_4 = noticia.param_4 || null;\nconst imagem_url = noticia.imagem_url || null;\n\n// 2) Pegar o dado binário cru do n8n\nconst inputBinaryData = $input.item?.binary?.data?.data;\nif (!inputBinaryData) {\n  throw new Error('Binário do arquivo não encontrado no node \"Download file\".');\n}\n\nlet finalBase64 = null;\nlet finalMime = null;\n\n// 3) Tentar decodificar como TEXTO primeiro\n// Se for um arquivo .txt contendo a string \"/9j/...\", isso vai revelar essa string.\nconst asText = Buffer.from(inputBinaryData, 'base64').toString('utf8').trim();\n\n// Regex para verificar se o texto decodificado PARECE ser um base64 de imagem\n// (Começa com /9j/ para JPG, iVBOR para PNG, ou data:image...)\nconst isTextContainingBase64 = /^(?:data:image\\/[a-zA-Z]+;base64,)?(?:\\/9j\\/|iVBOR|R0lG|UklGR|SUkq|TU0)/.test(asText);\n\nif (isTextContainingBase64) {\n  // CASO A: É um arquivo .txt que contém o texto da base64 dentro\n  // Usamos o texto decodificado, limpando quebras de linha ou espaços\n  let cleanContent = asText.replace(/\\s+/g, '');\n  \n  // Se tiver prefixo dataURI, removemos\n  const match = cleanContent.match(/^data:(.+);base64,(.+)$/i);\n  if (match) {\n    finalMime = match[1];\n    finalBase64 = match[2];\n  } else {\n    finalBase64 = cleanContent;\n  }\n} else {\n  // CASO B: É um arquivo de Imagem (Binário) salvo com extensão .txt\n  // O conteúdo do texto seria \"lixo\" (~)^+), então ignoramos o 'asText'.\n  // Usamos o binário original que o n8n nos entregou.\n  finalBase64 = inputBinaryData;\n}\n\n// 4) Detectar/Confirmar MIME type pelos \"magic bytes\" do base64 final\nif (!finalMime) {\n  const buf = Buffer.from(finalBase64, 'base64');\n  const sig = buf.slice(0, 4).toString('hex');\n  \n  if (sig.startsWith('ffd8')) finalMime = 'image/jpeg';\n  else if (sig === '89504e47') finalMime = 'image/png';\n  else if (sig.startsWith('474946')) finalMime = 'image/gif'; // GIF\n  else if (sig.startsWith('524946')) finalMime = 'image/webp'; // WebP\n  else finalMime = 'application/octet-stream';\n}\n\n// 5) Retorno\nreturn {\n  json: {\n    noticiaIndex: noticia.noticia_id,\n    legenda,\n    param_2,\n    param_3,\n    param_4,\n    imagem_url,\n    mimeType: finalMime,\n    base64: finalBase64\n  }\n};"
      },
