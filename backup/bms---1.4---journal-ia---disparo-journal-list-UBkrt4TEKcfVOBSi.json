        "jsCode": "// Normaliza o telefone do item atual\nconst raw = $json.telefone || \"\";\nlet clean = String(raw).replace(/\\D+/g, \"\"); // mantém só os dígitos\n\nif (clean.length === 11) {\n  clean = \"55\" + clean; // adiciona DDI se faltar\n} else if (clean.length === 13 && clean.startsWith(\"55\")) {\n  // já está ok\n}\n\n// Retorna o item original + o campo novo\nreturn {\n  json: {\n    ...$json,\n    telefoneAjustado: clean\n  }\n};\n"
