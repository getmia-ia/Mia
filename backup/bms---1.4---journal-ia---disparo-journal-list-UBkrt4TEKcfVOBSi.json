    {
      "parameters": {
        "jsCode": "// Cria um mapa para controlar quantas vezes cada telefone aparece\nconst contador = {};\n\n// Percorre todos os itens recebidos (Code7 está antes do Loop)\nreturn $input.all().map(item => {\n  const json = item.json;\n  const telefone = json.telefoneAjustado;\n\n  // Valor inicial vindo do Supabase\n  const mensagensHoje = json.mensagens_hoje || 0;\n\n  // Se o telefone ainda não foi visto neste lote, inicia com o valor atual do Supabase\n  if (!contador[telefone]) {\n    contador[telefone] = mensagensHoje;\n  }\n\n  // Incrementa 1 para esta ocorrência\n  contador[telefone]++;\n\n  // Retorna o item com o novo total\n  return {\n    json: {\n      ...json,\n      mensagens_hoje: contador[telefone],\n    },\n  };\n});\n"
      },
