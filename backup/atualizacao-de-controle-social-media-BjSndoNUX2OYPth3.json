    {
      "parameters": {
        "jsCode": "const discovery = $json.business_discovery;\n\nconst collectedAt = new Date().toISOString();\n\nreturn [\n  {\n    json: {\n      data_atualizacao: collectedAt,\n      username: discovery.username,\n      name: discovery.name,\n      followers_count: discovery.followers_count,\n      media_count: discovery.media_count\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        304
      ],
      "id": "08f6693b-fdc9-4793-b087-ec08a3ade141",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const discovery = $json.business_discovery;\nconst posts = discovery.media?.data || [];\n\nconst collectedAt = new Date().toISOString();\n\nreturn posts.map(post => {\n  return {\n    json: {\n      data_atualizacao: collectedAt,\n      username: discovery.username,\n      name: discovery.name,\n\n      post_id: post.id,\n      caption: post.caption || '',\n      media_type: post.media_type || '',\n      permalink: post.permalink || '',\n      timestamp: post.timestamp || '',\n      like_count: post.like_count || 0,\n      comments_count: post.comments_count || 0,\n      total_engagement: (post.like_count || 0) + (post.comments_count || 0),\n      engagement_rate_post: discovery.followers_count\n        ? Number((((post.like_count || 0) + (post.comments_count || 0)) / discovery.followers_count * 100).toFixed(4))\n        : 0\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
        -16
      ],
