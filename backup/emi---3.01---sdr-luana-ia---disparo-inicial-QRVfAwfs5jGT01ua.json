      "parameters": {
        "jsCode": "// ==========================\n// DEFINIÇÃO DOS TEMPLATES\n// ==========================\nconst templates = {\n  // --- IMERSÃO (padrão) --- vars: 2 → {{1}} nome, {{2}} tipo da imersão\n  imersao: {\n    name: \"campanha_leads_disparo_inicial\",\n    vars: 2,\n    text: \"Oii {{1}}! Aqui é a Luana da Escola do Mercado Imobiliário. \\n\\nVi que você se interessou pela nossa Imersão {{2}}.\\n\\nVocê já atua com incorporação ou está planejando começar seus primeiros projetos agora?\"\n  },\n  // --- ADVISOR --- vars: 1 → só {{1}} nome\n  advisor: {\n    name: \"campanha_leads_advisor_inicial\",\n    vars: 1,\n    text: \"Oii {{1}}! Aqui é a Luana da Escola do Mercado Imobiliário. \\n\\nVi que você se interessou pelo nosso programa Advisor.\\n\\nVocê já atua com incorporação ou está planejando começar seus primeiros projetos agora?\"\n  },\n  // --- ESCOLAFLIX --- vars: 1 → só {{1}} nome\n  escolaflix: {\n    name: \"campanha_leads_escolaflix_inicial\",\n    vars: 1,\n    text: \"Oii {{1}}! Aqui é a Luana da Escola do Mercado Imobiliário. Vi que você se interessou pela EscolaFlix.\\n\\nVocê já atua com incorporação ou está planejando começar seus primeiros projetos agora?\"\n  },\n  // --- MENTORIA --- vars: 1 → só {{1}} nome\n  mentoria: {\n    name: \"campanha_leads_mentoria_inicial\",\n    vars: 1,\n    text: \"Oii {{1}}! Aqui é a Luana da Escola do Mercado Imobiliário. Vi que você se interessou pela nossa Mentoria.\\n\\nVocê já atua com incorporação ou está planejando começar seus primeiros projetos agora?\"\n  }\n};\n\n// ==========================\n// PROCESSADOR PRINCIPAL\n// ==========================\nconst entrada = $('Prepara Variáveis do Lead').first().json;\n\n// ==========================\n// SELEÇÃO DO TEMPLATE POR PRODUTO\n// ==========================\nconst produto = (entrada.produto || \"\").toString().toLowerCase().trim();\n\nlet templateEscolhido;\n\nif (!entrada.produto || produto === \"\" || produto.includes(\"imersão\") || produto.includes(\"imersao\")) {\n  templateEscolhido = templates.imersao;\n} else if (produto.includes(\"advisor\")) {\n  templateEscolhido = templates.advisor;\n} else if (produto.includes(\"escolaflix\")) {\n  templateEscolhido = templates.escolaflix;\n} else if (produto.includes(\"mentoria\")) {\n  templateEscolhido = templates.mentoria;\n} else {\n  // Fallback seguro: cai no template da imersão\n  templateEscolhido = templates.imersao;\n}\n\n// ==========================\n// MONTAGEM DO BODY DO WHATSAPP\n// ==========================\nconst body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.telefoneAjustado || \"\"),\n  type: \"template\",\n  template: {\n    name: templateEscolhido.name,\n    language: { code: \"pt_BR\" },\n    components: []\n  }\n};\n\n// ==========================\n// VARIÁVEIS DO TEMPLATE\n// ==========================\nconst parameters = [];\nif (templateEscolhido.vars >= 1) {\n  parameters.push({ type: \"text\", text: String(entrada.var_1 || \"\") });\n}\nif (templateEscolhido.vars >= 2) {\n  parameters.push({ type: \"text\", text: String(entrada.var_2 || \"\") });\n}\n\nbody.template.components.push({\n  type: \"body\",\n  parameters\n});\n\n// ==========================\n// TEXTO FINAL PARA HISTÓRICO\n// ==========================\nlet textoFinal = templateEscolhido.text\n  .replace(\"{{1}}\", entrada.var_1 || \"\")\n  .replace(\"{{2}}\", entrada.var_2 || \"\");\n\n// ==========================\n// RETORNO FINAL FORMATADO\n// ==========================\nreturn [\n  {\n    json: {\n      resultado: body,\n      mensagem_final: textoFinal,\n      template_usado: templateEscolhido.name,\n      produto_identificado: produto || \"imersao (padrão)\"\n    }\n  }\n];"
      },
