    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\nconst mensagem = `Olá, ${item.nome}. Tudo bem?\\n\\nMuito prazer, eu sou a Mia, da M[IA]! Nós somos especialistas em implementar Inteligência Artificial em empresas como a ${item.empresa}.\\n\\nEmpresas que trabalham conosco estão automatizando processos operacionais, reduzindo os seus custos e transformando seu atendimento com IA, tudo isso sem complicação.\\n\\nFaz sentido termos uma conversa sobre como isso funcionaria na prática para a ${item.empresa}?\\n\\nFico à disposição! 😊`;\n\nreturn {\n  json: {\n    messaging_product: \"whatsapp\",\n    to: item.telefone_normalizado,\n    type: \"template\",\n    template: {\n      name: \"mia_disparo_inicial\",\n      language: {\n        code: \"pt_BR\"\n      },\n      components: [\n        {\n          type: \"body\",\n          parameters: [\n            {\n              type: \"text\",\n              text: item.nome\n            },\n            {\n              type: \"text\",\n              text: item.empresa\n            },\n            {\n              type: \"text\",\n              text: item.empresa\n            }\n          ]\n        }\n      ]\n    },\n    mensagem_pronta: mensagem\n  }\n};"
      },
