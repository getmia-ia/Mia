    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function ajustarTelefone(raw) {\n  if (!raw) return null;\n  let t = raw.toString().replace(/\\D/g, \"\");\n  t = t.replace(/^0+/, \"\");\n  if (t.length === 8) {\n    t = \"11\" + \"9\" + t;\n  } else if (t.length === 9) {\n    t = \"11\" + t;\n  } else if (t.length === 10) {\n    t = t.replace(/^(\\d{2})(\\d{8})$/, \"$19$2\");\n  } else if (t.length === 11) {\n    t = \"55\" + t;\n  } else if (t.length === 12) {\n    t = t.slice(0, 4) + \"9\" + t.slice(4);\n  } else if (t.length > 13) {\n    t = t.slice(-13);\n  }\n  return t;\n}\n\nconst item = $input.item.json;\nconst telefoneNormalizado = ajustarTelefone(item.body.telefone);\n\nreturn {\n  json: {\n    ...item.body,\n    telefone_normalizado: telefoneNormalizado\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
