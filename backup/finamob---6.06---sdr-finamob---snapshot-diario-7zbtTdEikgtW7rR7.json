        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"resumo_historico\": { \"type\": \"string\" },\n    \"temperatura_lead\": { \"type\": \"string\" },\n    \"principal_barreira\": { \"type\": \"string\" }\n  },\n  \"required\": [\"resumo_historico\", \"temperatura_lead\", \"principal_barreira\"]\n}"
      },
