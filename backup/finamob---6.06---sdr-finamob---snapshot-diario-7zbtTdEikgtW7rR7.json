      ],
      "id": "2683f43e-4e08-4275-af8d-b942f70ee63f",
      "name": "Loop Over Items"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=select mensagem_usuario, mensagem_agente\nfrom \"finamob-historico_mensagens\"\nwhere telefone = '{{ $json.telefone }}'\n  and message_type = 'text'\norder by created_at asc;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        896,
        -80
      ],
      "id": "343fabae-a363-4bfd-89f8-9eb7e9629f9c",
      "name": "Histórico do Lead",
      "credentials": {
        "postgres": {
          "id": "htyT6TWxXxRh5mZQ",
          "name": "Postgres N8N workflow"
        }
      },
      "notes": "SELECIONAR CREDENCIAL postgres."
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nlet hist = '';\nfor (const r of rows) {\n  const u = (r.json.mensagem_usuario || '').trim();\n  const a = (r.json.mensagem_agente || '').trim();\n  if (u) hist += 'Lead: ' + u + '\\n';\n  if (a) hist += 'SDR: ' + a + '\\n';\n}\nreturn { json: { historico: hist, telefone: $('Loop Over Items').item.json.telefone } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -80
      ],
      "id": "a18115d5-33b0-485a-a8cb-1e4f9a35d23b",
      "name": "Formata Histórico"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.historico }}",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "Analise a conversa abaixo entre Lead e SDR. Retorne JSON seguindo exatamente o schema do output parser:\n- resumo_historico: resumo curto da conversa em poucas palavras.\n- temperatura_lead: UMA de [Sem histórico, Perdido, Muito quente, Quente, Morno, Frio].\n- principal_barreira: UMA de [Sem interesse, Sem barreira clara, Falta de prioridade, Insegurança pessoal, Credibilidade, Tempo, Preço].\n\nNão invente. Use exclusivamente as opções listadas (valores exatos, com acentos e maiúsculas iguais)."
            }
          ]
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        1344,
        -80
      ],
      "id": "57d54a89-0a28-47d0-86bf-0801e786198f",
      "name": "Classifica Lead"
    },
