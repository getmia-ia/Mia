    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select h.telefone,\n       sum(length(coalesce(h.mensagem_usuario,'') || coalesce(h.mensagem_agente,''))) as chars_atual\nfrom \"finamob-historico_mensagens\" h\nwhere h.created_at > now() - interval '30 days'\n  and h.message_type = 'text'\ngroup by h.telefone\nhaving sum(length(coalesce(h.mensagem_usuario,'') || coalesce(h.mensagem_agente,'')))\n     - coalesce((select last_chars from mailing_snapshot s where s.telefone = h.telefone), 0) > 500;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        448,
        64
      ],
      "id": "ed2d5eef-d6a2-450c-acb5-d8ca4c26d32b",
      "name": "Seleciona Candidatos",
      "notesInFlow": true,
      "credentials": {
        "postgres": {
          "id": "htyT6TWxXxRh5mZQ",
          "name": "Postgres N8N workflow"
        }
      },
      "notes": "Retorna só leads com >500 chars novos desde o último snapshot. SELECIONAR CREDENCIAL postgres."
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        672,
