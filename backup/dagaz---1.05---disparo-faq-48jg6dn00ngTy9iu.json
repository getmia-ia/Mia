        "parameters": {
          "jsCode": "// AQUI ESTAVA O ERRO: Os dados estão dentro de .body\nconst entrada = items[0].json.body; \n\n// Verifica se deve usar template\nconst usarTemplate = entrada.use_template === true;\n\nlet body = {\n  messaging_product: \"whatsapp\",\n  to: String(entrada.phone),\n};\n\nif (usarTemplate) {\n  // --- CASO 1: TEMPLATE (Fora de 24h) ---\n  body.type = \"template\";\n  body.template = {\n    name: entrada.template_name,\n    language: { code: \"pt_BR\" }\n  };\n} else {\n  // --- CASO 2: TEXTO LIVRE (Dentro de 24h) ---\n  body.type = \"text\";\n  body.text = {\n    preview_url: false,\n    body: entrada.message || \"Sem mensagem definida\" // Fallback de segurança\n  };\n}\n\nreturn [{\n  json: {\n    resultado: body,\n    use_template: usarTemplate,\n    mensagem_para_historico: entrada.message,\n    // Garante que o ID venha do objeto 'body' corretamente\n    whatsapp_number_id: entrada.whatsapp_number_id \n  }\n}];"
