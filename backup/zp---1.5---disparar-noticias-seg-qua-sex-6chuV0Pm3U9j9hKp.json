        "url": "={{\n  $('Encontra a Próxima Notícia Válida').item.json.imagem_url\n    .replace(\n      /^https:\\/\\/raw\\.githubusercontent\\.com\\/([^/]+)\\/([^/]+)\\/([^/]+)\\/(.*)$/,\n      'https://cdn.jsdelivr.net/gh/$1/$2/$4'\n    )\n}}\n",
