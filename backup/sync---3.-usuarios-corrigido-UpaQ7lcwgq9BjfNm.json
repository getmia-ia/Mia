    {
      "parameters": {
        "jsCode": "// 1. Acessa a memória do workflow\nconst staticData = $getWorkflowStaticData('global');\n\n// 2. Verifica se a chamada veio do \"Disparar Webhook\" (início de tudo)\n// Usamos interrogação (?.) para evitar erro se o json estiver vazio\nconst isInitial = $input.first()?.json?.fromStart === true;\n\n// 3. Se for o início do dia, reseta o contador para zero\nif (isInitial) {\n  staticData.offset = 0;\n}\n\n// 4. Retorna o offset atual (ou 0 se for a primeira vez) para o Postgres usar\nreturn [{ \n  json: { \n    offset: staticData.offset || 0 \n  } \n}];"
      },
