    {
      "parameters": {
        "jsCode": "// Pega o image_url do node anterior (Set)\nconst image_url = $items(\"Edit Fields\")[0].json.image_url;\n\n// Pega todas as linhas do Sheets\nconst rows = $input.all();\n\n// Cria a saída final com o telefone formatado e o image_url incluso\nreturn rows.map(item => {\n  const data = item.json;\n\n  // Normalização do telefone\n  const raw = data.telefone || \"\";\n  let clean = String(raw).replace(/\\D+/g, \"\");\n\n  if (clean.length === 11) {\n    clean = \"55\" + clean;\n  } else if (clean.length === 13 && clean.startsWith(\"55\")) {\n    // já está ok\n  }\n\n  return {\n    json: {\n      ...data,\n      telefoneFormatado: clean,\n      image_url: image_url // 🔧 pega do node anterior (Set)\n    }\n  };\n});\n"
      },
