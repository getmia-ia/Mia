      "parameters": {
        "content": "# Seta os Parametros\n\n   - **Avatar ID** \n   - **Voice ID** \n   - **Texto**",
        "height": 400,
        "width": 480,
        "color": 5
      },
      "id": "13a9c748-f628-4375-aa61-e1fd7b1256da",
      "name": "Sticky Note3",
