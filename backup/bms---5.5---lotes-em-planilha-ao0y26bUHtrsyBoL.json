      {
        "parameters": {
          "jsCode": "const sheetData = $node[\"Capta os dados da planilha\"].json;\nconst placeholders = $node[\"Webhook\"].json.body.placeholderList;\n\n// função normalização\nfunction normalize(str) {\n  return str\n    .toLowerCase()\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/[^a-z0-9]+/g, \"_\")\n    .replace(/^_|_$/g, \"\");\n}\n\n// função data\nfunction formatDateBR() {\n  const now = new Date();\n  const day = now.getDate();\n\n  const months = [\n    \"janeiro\", \"fevereiro\", \"março\", \"abril\", \"maio\", \"junho\",\n    \"julho\", \"agosto\", \"setembro\", \"outubro\", \"novembro\", \"dezembro\"\n  ];\n\n  return `${day} de ${months[now.getMonth()]} de ${now.getFullYear()}`;\n}\n\n// normalização\nconst normalizedData = {};\n\nfor (const key in sheetData) {\n  normalizedData[normalize(key)] = sheetData[key];\n}\n\n// 🔥 adiciona campo global\nnormalizedData[\"data_submissao\"] = formatDateBR();\n\n// 🔥 garante inclusão\nconst allKeys = [\n  ...placeholders,\n  \"data_submissao\"\n];\n\n// monta requests\nconst requests = allKeys\n  .filter(key => normalizedData[key] !== undefined)\n  .map(key => ({\n    replaceAllText: {\n      containsText: {\n        text: `{{${key}}}`,\n        matchCase: true\n      },\n      replaceText: String(normalizedData[key] ?? \"\")\n    }\n  }));\n\nreturn [\n  {\n    json: {\n      documentId: $node[\"Duplica o Template\"].json.id,\n      requests\n    }\n  }\n];"
        },
