        "jsCode": "const webhook = $node[\"Webhook\"].json.body;\n\n// 🔥 dados da linha (DO LOOP)\nconst sheetData = $node[\"Loop Over Items1\"].json;\n\n// 🔥 urls (node atual)\nconst urls = $json;\n\n// documentId vindo da duplicação\nconst documentId = $node[\"Duplica o Template\"].json.id;\n\n// nome do arquivo (com fallback)\nconst nomeArquivo = $('Duplica o Template').first().json.name;\n\nreturn [{\n  json: {\n    batchId: webhook.batchId,\n    rowIndex: sheetData.row_number || $itemIndex + 1,\n\n    userId: webhook.userId,\n    tipoModelo: webhook.templateNome,\n    templateId: webhook.templateId,\n\n    nomeArquivo,\n\n    documentoGeradoUrlPdf: urls.url_pdf || null,\n    documentoGeradoUrlDocx: urls.url_docx || null,\n    documentoGeradoUrlEdit: urls.url_view || null,\n\n    dadosExtraidos: sheetData,\n\n    erro: null\n  }\n}];"
