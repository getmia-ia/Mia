    {
      "parameters": {
        "jsCode": "// Recupera todos os itens de entrada\nconst items = $input.all().map(i => i.json);\n\n// --- 1. CONFIGURAÇÕES GERAIS ---\nconst TOTAL_LEMBRETES = $input.first().json.total_pre_evento_messages; \n\n// --- 2. SEPARAÇÃO DAS ENTIDADES ---\n// Identifica Template (busca por meta_template_name OU message_template)\nconst template = items.find(i => (i.meta_template_name || i.message_template));\n\n// Identifica Evento (busca por nome_evento e data)\nconst event = items.find(i => i.nome_evento && i.data_hora_inicio);\n\n// Identifica Participantes (quem tem telefone e não é template nem evento)\nconst participants = items.filter(i => \n  i.phone && \n  !i.meta_template_name && \n  !i.message_template &&\n  !i.nome_evento\n);\n\n// --- 3. FUNÇÕES AUXILIARES (HELPERS) ---\n\nfunction normalizePhone(phone) {\n  if (!phone) return null;\n  let digits = phone.toString().replace(/\\D/g, '');\n  // Tratamento Brasil\n  if (digits.length >= 10 && digits.length <= 11) {\n    digits = '55' + digits;\n  }\n  return digits;\n}\n\nfunction normalizeText(text) {\n  if (!text) return '';\n  return text.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n}\n\nfunction formatDate(isoDate) {\n  if (!isoDate) return '';\n  return new Date(isoDate).toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n}\n\nfunction formatTime(isoDate) {\n  if (!isoDate) return '';\n  return new Date(isoDate).toLocaleTimeString('pt-BR', {\n    hour: '2-digit',\n    minute: '2-digit',\n    timeZone: 'America/Sao_Paulo'\n  });\n}\n\nfunction getAddress(event) {\n    if (!event) return '';\n    if (event.tipo_local === 'online' && event.link_online) {\n        return event.link_online;\n    }\n    return event.endereco_completo || event.local_evento || (event.cidade ? `${event.cidade}-${event.estado}` : '');\n}\n\n// --- 4. RESOLUÇÃO INTELIGENTE DE VARIÁVEIS ---\nfunction resolveVariable(variableName, participant, event) {\n  const name = normalizeText(variableName);\n\n  const systemMap = {\n    // --- EVENTO ---\n    'nome_evento': event?.nome_evento,\n    'evento': event?.nome_evento,\n    \n    'data_evento': formatDate(event?.data_hora_inicio),\n    'data': formatDate(event?.data_hora_inicio),\n    \n    'hora_evento': formatTime(event?.data_hora_inicio),\n    'hora': formatTime(event?.data_hora_inicio),\n    \n    'data_final': formatDate(event?.data_hora_fim),\n    'hora_final': formatTime(event?.data_hora_fim),\n    \n    'local_evento': event?.local_evento,\n    'endereco': getAddress(event),\n    'link_online': event?.link_online,\n    \n    'organizador': event?.organizador,\n    \n    // --- PARTICIPANTE ---\n    'nome_participante': participant.name,\n    'nome': participant.name,\n    'primeiro_nome': participant.name ? participant.name.split(' ')[0] : '',\n    'telefone': participant.phone,\n    'empresa': participant.company || ''\n  };\n\n  if (systemMap[name] !== undefined) return systemMap[name];\n\n  if (name.includes('nome') && name.includes('participante')) return participant.name;\n  if (name.includes('nome') && name.includes('evento')) return event?.nome_evento;\n  if (name.includes('data')) return formatDate(event?.data_hora_inicio);\n  if (name.includes('hora')) return formatTime(event?.data_hora_inicio);\n\n  return ''; \n}\n\n// --- 5. PROCESSAMENTO PRINCIPAL ---\n\nreturn participants.map(participant => {\n  \n  // A. Lógica de Classificação\n  const reminder_number = participant.current_reminder || 0;\n  const status = participant.status;\n  \n  let tipo;\n  let is_ultimo = (reminder_number >= TOTAL_LEMBRETES);\n\n  if (status === 'approved' || status === 'invited' || reminder_number === 0) {\n    tipo = 'iniciar_jornada';\n  } else if (is_ultimo) {\n    tipo = 'finalizar';\n  } else {\n    tipo = 'lembrete';\n  }\n\n  // B. Resolução dos Parâmetros\n  const parameters = (template?.variables || []).map(variableName => \n    resolveVariable(variableName, participant, event)\n  );\n\n  // C. Lógica de Mídia Unificada (CORRIGIDA)\n  \n  // 1. Busca URL de VIDEO em todas as variações de chaves possíveis\n  const videoUrl = template?.mapping_header_video_url || \n                   template?.template_header_video_url || \n                   template?.header_video_url;\n\n  // 2. Busca URL de IMAGEM em todas as variações de chaves possíveis\n  const imageUrl = template?.mapping_header_image_url || \n                   template?.template_header_image_url || \n                   template?.header_image_url || \n                   event?.imagem_url_convite || \n                   event?.banner_url;\n  \n  // Define a URL final (Prioridade para Video se existir, senão Imagem)\n  const finalMediaUrl = videoUrl || imageUrl || null;\n\n  // 3. Define o tipo (media_type)\n  let finalMediaType = template?.media_type || null; \n  \n  // Ajuste de segurança: Se achamos uma URL de vídeo, forçamos o tipo 'video'\n  if (videoUrl) {\n      finalMediaType = 'video';\n  } else if (imageUrl && !finalMediaType) {\n      // Se achamos imagem e o tipo veio nulo, forçamos 'image'\n      finalMediaType = 'image';\n  }\n\n  // Fallback final por extensão se ainda estiver nulo\n  if (finalMediaUrl && !finalMediaType) {\n      if (finalMediaUrl.endsWith('.mp4')) {\n          finalMediaType = 'video';\n      } else {\n          finalMediaType = 'image';\n      }\n  }\n\n  // D. Retorno Final\n  return {\n    json: {\n      participant_id: participant.id,\n      event_id: participant.event_id || event?.id,\n      \n      tipo_acao: tipo,\n      reminder_number: reminder_number,\n      status: status,\n      \n      phone: normalizePhone(participant.phone),\n      \n      message_template: template?.message_template,\n      meta_template_name: template?.meta_template_name,\n      parameters: parameters,\n      \n      requires_image: template?.requires_image || false,\n      \n      // Mídia corrigida\n      media_url: finalMediaUrl, \n      media_type: finalMediaType,\n      \n      hasMedia: !!finalMediaUrl\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
        208
      ],
      "id": "d3950746-817a-437c-8a11-539e159f69c8",
      "name": "Classificação do participante, normalização do telefone e o preenchimento inteligente das variáveis"
    },
    {
      "parameters": {
        "jsCode": "// ========================\n// Utilitários\n// ========================\n\nfunction montarMensagem(template, params) {\n  if (!template) return \"\";\n\n  let msg = template;\n  const safeParams = Array.isArray(params) ? params : [];\n\n  safeParams.forEach((valor, index) => {\n    const placeholder = new RegExp(`{{\\\\s*${index + 1}\\\\s*}}`, \"g\");\n    msg = msg.replace(placeholder, valor ?? \"\");\n  });\n\n  return msg;\n}\n\nfunction normalizeTelefone(raw) {\n  if (raw == null) return \"\";\n  let d = String(raw).replace(/\\D/g, \"\").replace(/^0+/, \"\");\n  return d ? (d.startsWith(\"55\") ? d : \"55\" + d) : \"\";\n}\n\n// ========================\n// Execução principal\n// ========================\n\nreturn items.map((item) => {\n  const json = item.json;\n\n  // 1. Mapeamento de Campos\n  const mensagemTemplate = json.message_template || json.mensagem || \"\";\n  const nome = json.nome_participante || json.nome || \"\";\n  const telefone = normalizeTelefone(json.phone || json.telefone);\n  const template_name = json.meta_template_name || json.template_name || \"\";\n  const participant_id = json.participant_id;\n  const status = json.status || \"pending\";\n  const tipo_acao = json.tipo_acao;\n  const reminder_number = json.reminder_number;\n  \n  // 2. Tratamento de Parâmetros\n  let params = [];\n  \n  if (Array.isArray(json.parameters)) {\n    params = json.parameters;\n  } else {\n    // Busca param_0, param_1, etc.\n    Object.keys(json).forEach((key) => {\n      if (key.startsWith(\"param_\")) {\n        const index = Number(key.replace(\"param_\", \"\"));\n        params[index] = json[key];\n      }\n    });\n  }\n\n  // --- CORREÇÃO PRINCIPAL ---\n  // Remove valores nulos, undefined ou strings vazias para enviar limpo ao WhatsApp\n  // Ex: transforma [\"Taysa\", null, null] em [\"Taysa\"]\n  params = params.filter(p => p !== null && p !== undefined && p !== \"\");\n\n  // 3. Tratamento de Mídia\n  // Lê todas as variações possíveis vindas dos nós anteriores\n  const rawMediaUrl = json.media_url || json.midia_url || json.image_url || \"\";\n  const media_url = rawMediaUrl.toString().trim();\n  \n  let media_type = (json.media_type || \"\").toLowerCase();\n  \n  // Detecção automática de tipo se tiver URL mas não tiver tipo\n  if (media_url && !media_type) {\n      if (media_url.endsWith('.mp4')) {\n          media_type = 'video';\n      } else {\n          media_type = 'image';\n      }\n  }\n\n  const hasMedia = !!media_url && (media_type === 'image' || media_type === 'video');\n  const isTextOnly = !hasMedia;\n\n  // 4. Montagem da Mensagem (Preview)\n  const mensagem_completa = montarMensagem(mensagemTemplate, params);\n\n  // ========================\n  // Retorno\n  // ========================\n  return {\n    json: {\n      participant_id,\n      telefone,\n      nome,\n      status,\n      tipo_acao,\n      reminder_number,\n      template_name,\n      \n      mensagem_completa,\n      \n      // Array limpo, pronto para a API\n      parameters: params,\n\n      hasMedia,\n      isTextOnly,\n      media_type: hasMedia ? media_type : null,\n      media_url:  hasMedia ? media_url  : null,\n      \n      // Sincroniza requires_image com a existência de mídia real ou a flag original\n      requires_image: json.requires_image || hasMedia\n    }\n  };\n});"
      },
