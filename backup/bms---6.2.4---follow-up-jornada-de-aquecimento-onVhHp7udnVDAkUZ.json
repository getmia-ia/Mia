      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  e.id AS evento_id,\n  e.nome_evento,\n  e.data_hora_inicio,\n  e.local_evento,\n  e.endereco_completo,\n  etm.dias_antes_evento,\n  etm.template_id,\n  etm.header_image_url,\n  etm.header_video_url,\n  em.meta_template_name,\n  em.variables,\n  -- Número do lembrete (ordenado do mais distante para o mais próximo)\n  ROW_NUMBER() OVER (\n    PARTITION BY e.id \n    ORDER BY etm.dias_antes_evento DESC\n  ) AS reminder_number,\n  -- Total de lembretes para este evento\n  COUNT(*) OVER (PARTITION BY e.id) AS total_lembretes\nFROM eventos e\nJOIN evento_template_mapping etm ON e.id = etm.evento_id\nJOIN event_messages em ON etm.template_id = em.id\nWHERE \n  e.status = 'ativo'\n  AND etm.message_type = 'pre_evento'\n  AND em.meta_status = 'approved'\n  AND DATE(\n  e.data_hora_inicio AT TIME ZONE 'America/Sao_Paulo'\n  - INTERVAL '1 day' * etm.dias_antes_evento\n) = CURRENT_DATE\nORDER BY e.data_hora_inicio ASC\n",
        "options": {}
      },
