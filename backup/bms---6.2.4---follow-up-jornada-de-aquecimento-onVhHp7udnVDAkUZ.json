    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  -- Campos do mapeamento (evento_template_mapping)\n  etm.id as mapping_id,\n  etm.evento_id,\n  etm.template_id,\n  etm.message_type as mapping_message_type,\n  etm.dias_antes_evento as mapping_dias_antes_evento,\n  etm.header_image_url as mapping_header_image_url,\n  etm.header_video_url as mapping_header_video_url,\n  etm.created_at as mapping_created_at,\n  \n  -- Campos do template (event_messages)\n  em.id as template_id,\n  em.name as template_name,\n  em.message_template,\n  em.message_type as template_message_type,\n  em.meta_template_name,\n  em.meta_template_id,\n  em.meta_status,\n  em.meta_rejection_reason,\n  em.category,\n  em.language,\n  em.header_image_url as template_header_image_url,\n  em.header_video_url as template_header_video_url,\n  em.media_type,\n  em.waba_id,\n  em.enabled,\n  em.requires_image,\n  em.variables,\n  em.variable_samples,\n  em.dias_antes_evento as template_dias_antes_evento,\n  em.submitted_at,\n  em.created_at as template_created_at,\n  em.updated_at as template_updated_at,\n  \n  -- Contagem total de mensagens pré-evento da jornada\n  (SELECT COUNT(*) \n   FROM evento_template_mapping sub \n   WHERE sub.evento_id = etm.evento_id \n   AND sub.message_type = 'pre_evento') as total_pre_evento_messages\n\nFROM evento_template_mapping etm\nINNER JOIN event_messages em ON etm.template_id = em.id\nWHERE etm.evento_id = '{{ $json.evento_id }}' \n  AND etm.template_id = '{{ $json.template_id }}'\nORDER BY \n  etm.message_type,\n  etm.dias_antes_evento\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -432,
        208
      ],
      "id": "b066ce0b-a3a6-4238-99c5-d9038ad01db2",
