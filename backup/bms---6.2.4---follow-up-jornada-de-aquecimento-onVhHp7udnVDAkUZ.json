      "parameters": {
        "operation": "executeQuery",
        "query": "-- Query SQL\nSELECT \n  id,\n  name,\n  email,\n  phone,\n  company,\n  position,\n  status,\n  confirmed,\n  confirmed_at,\n  dispatch_count,\n  current_reminder,\n  created_at\nFROM event_guests\nWHERE event_id = '{{ $json.evento_id }}'\n  AND status = 'approved'\n  OR status = 'journey'\nORDER BY name;\n",
