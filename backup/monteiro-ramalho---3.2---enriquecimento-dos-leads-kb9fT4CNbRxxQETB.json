    {
      "parameters": {
        "jsCode": "const truncate = (s, n) => (typeof s === \"string\" && s.length > n ? s.slice(0, n) : s ?? null);\nconst clean = (v) => (v === undefined || v === \"\" ? null : v);\n\nconst normalizePhone = (phone) => {\n  if (!phone) return null;\n\n  // Remove tudo que não é número\n  let digits = String(phone).replace(/\\D/g, \"\");\n\n  // Remove código do país caso venha duplicado (5555...)\n  while (digits.startsWith(\"5555\")) {\n    digits = digits.slice(2);\n  }\n\n  // Se não tiver DDI, adiciona 55\n  if (!digits.startsWith(\"55\")) {\n    digits = \"55\" + digits;\n  }\n\n  // Após o DDI devem existir DDD + número\n  const ddd = digits.slice(2, 4);\n  let number = digits.slice(4);\n\n  // Celular antigo (8 dígitos) -> adiciona 9\n  if (number.length === 8) {\n    number = \"9\" + number;\n  }\n\n  return `55${ddd}${number}`;\n};\n\nconst inputs = items.map((i) => i.json).flat();\n\nreturn inputs.map((c) => {\n  const size = Array.isArray(c.companySize) ? c.companySize.filter((n) => n != null) : [];\n  const empresa_tamanho =\n    size.length === 2 ? `${size[0]}-${size[1]}` : size[0] != null ? String(size[0]) : null;\n\n  const companyId = c?.raw?.contact?.data?.companyId ?? null;\n  const fullName =\n    c.fullName || [c.firstName, c.lastName].filter(Boolean).join(\" \").trim() || null;\n\n  // remove `raw` do payload salvo em dados_enriquecimento\n  const { raw, ...enriquecimentoSemRaw } = c;\n\n  return {\n    json: {\n      nome: fullName,\n      cargo: clean(c.jobTitle),\n      email: clean(c.primaryEmail),\n      telefone: normalizePhone(c.primaryPhone),\n      linkedin_url: clean(c.linkedinProfile),\n      empresa_nome: clean(c.companyName),\n      empresa_site: clean(c.companyHomepage || c.companyDomain),\n      empresa_setor: clean(c.companySubIndustry || c.companyMainIndustry),\n      empresa_tamanho: empresa_tamanho,\n      empresa_descricao: truncate(c.companyDescription, 4000),\n      lusha_contact_id: c.personId != null ? String(c.personId) : null,\n      id_company_lusha: companyId != null ? String(companyId) : null,\n      dados_enriquecimento: enriquecimentoSemRaw,\n      etapa: \"enrich\",\n    },\n  };\n});"
      },
