    {
      "parameters": {
        "jsCode": "// Pega todas as linhas\nconst rows = items.map(i => i.json);\n\n// Função pra checar se está aprovado\nconst isApproved = v => String(v || '').trim().toLowerCase() === 'aprovado';\n\n// Acha o primeiro item aprovado\nconst first = rows.find(r => isApproved(r.status_linkedin));\n\nif (!first) return [];\n\nreturn [{ json: { ...first, status_retorno: first.status_linkedin } }];"
      },
