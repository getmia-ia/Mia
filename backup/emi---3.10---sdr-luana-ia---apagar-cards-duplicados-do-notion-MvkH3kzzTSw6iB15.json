    {
      "parameters": {
        "jsCode": "// --- Função de normalização ---\nfunction normalizePhone(raw) {\n  if (!raw) return \"\";\n\n  // 1. Remove tudo que não é número\n  let num = String(raw).replace(/\\D/g, \"\");\n\n  // 2. Remove prefixos tipo 00 ou +\n  if (num.startsWith(\"00\")) num = num.slice(2);\n\n  // 3. Garante que começa com 55 (Brasil)\n  if (!num.startsWith(\"55\")) {\n    num = \"55\" + num;\n  }\n\n  // Agora temos: 55DD[9]NNNNNNNN (10 ou 11 dígitos após 55)\n\n  // 4. Após 55, validar DDD e número\n  let rest = num.slice(2); // DDD + número\n\n  // Se tiver só 10 dígitos depois de 55 → sem o 9 do celular\n  if (rest.length === 10) {\n    // coloca o 9 depois do DDD\n    rest = rest.slice(0, 2) + \"9\" + rest.slice(2);\n  }\n\n  // 5. Reconstrói o número final\n  return \"55\" + rest;\n}\n\n\n// ==================================================\n\nconst inputData = $input.first().json.pages || [];\n\nconst groups = Object.create(null);\n\ninputData.forEach(item => {\n  let phoneRaw = item.property_to_check;\n\n  // 🚨 Se for null, undefined ou vazio → ignora\n  if (!phoneRaw) return;\n\n  let phone = normalizePhone(phoneRaw);\n\n  // Se depois de normalizar ainda ficar vazio, ignora\n  if (!phone) return;\n\n  if (!groups[phone]) groups[phone] = [];\n  groups[phone].push(item);\n});\n\n\nconst itemsToDelete = [];\n\nfor (const phone in groups) {\n  const group = groups[phone];\n\n  if (group.length > 1) {\n    group.sort((a, b) => {\n      const ta = Date.parse(a.created_time) || 0;\n      const tb = Date.parse(b.created_time) || 0;\n      return ta - tb;\n    });\n\n    // Mantém só o mais recente\n    const toDelete = group.slice(0, -1);\n\n    for (const dup of toDelete) {\n      itemsToDelete.push({ json: dup });\n    }\n  }\n}\n\nreturn itemsToDelete;"
      },
