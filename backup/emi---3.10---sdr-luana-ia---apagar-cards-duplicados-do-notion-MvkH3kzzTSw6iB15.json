      "parameters": {
        "jsCode": "// ============================\n// FUNÇÃO PARA PADRONIZAR TELEFONE\n// ============================\nfunction padronizarTelefone(raw) {\n  if (!raw) return null;\n\n  // Remove tudo que não é número\n  let t = raw.toString().replace(/\\D/g, \"\");\n\n  // Remove zeros iniciais inúteis (ex: 011)\n  t = t.replace(/^0+/, \"\");\n\n  // Caso 1: 8 dígitos (sem DDD, sem 9)\n  if (t.length === 8) {\n    t = \"11\" + \"9\" + t;\n  }\n  // Caso 2: 9 dígitos (sem DDD, com 9)\n  else if (t.length === 9) {\n    t = \"11\" + t;\n  }\n  // Caso 3: 10 dígitos (DDD + número sem 9)\n  else if (t.length === 10) {\n    t = t.slice(0, 2) + \"9\" + t.slice(2);\n  }\n  // Caso 4: 11 dígitos (DDD + número com 9)\n  else if (t.length === 11) {\n    t = \"55\" + t;\n  }\n  // Caso 5: 12 dígitos (55 + DDD + número sem 9)\n  else if (t.length === 12) {\n    t = t.slice(0, 4) + \"9\" + t.slice(4);\n  }\n  // Caso 6: 13 dígitos (perfeito)\n  else if (t.length > 13) {\n    t = t.slice(-13);\n  }\n\n  return t;\n}\n\n\n// ============================\n// COLETO OS DADOS DO JEITO DO SEU PRINT\n// ============================\n\nconst inputData = $input.first().json.pages || [];\n\n// ============================\n// PROCESSAMENTO DOS ITEMS\n// ============================\n\nreturn inputData.map(item => {\n  const id = item.id;\n  const original = item.property_to_check;\n  const ajustado = padronizarTelefone(original);\n\n  return {\n    json: {\n      id,\n      original,\n      contatoAjustado: ajustado\n    }\n  };\n});\n"
      },
