    {
      "parameters": {
        "jsCode": "const workflowName = $('Captura Erro').item.json.workflow.name;\n\n// Pega o primeiro bloco do nome e normaliza\nconst cliente = workflowName.split(' ')[0].toLowerCase();\n\n// Cliente -> Responsável\nconst responsaveis = {\n  'tools': 'Herik',\n  'dagaz': 'Herik',\n  'mia': 'Herik',\n  'avlog': 'Herik',\n  'emi': 'Sofia',\n  'finamob': 'Taysa',\n  'bms': 'Taysa',\n  'apis': 'Taysa',\n  'agronegociar': 'Gabriel',\n  'pantynova': 'Gabriel',\n  'eleva': 'Gabriel'\n};\n\n// Responsável -> Telefone\nconst telefones = {\n  'Gabriel': '5511969433278',\n  'Herik': '5538998634756',\n  'Taysa': '5534992150692'\n};\n\nconst responsavel = responsaveis[cliente] || 'Não identificado';\nconst tel_resp = telefones[responsavel] || null;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    responsavel,\n    tel_resp,\n    cliente_identificado: cliente\n  }\n}];"
      },
