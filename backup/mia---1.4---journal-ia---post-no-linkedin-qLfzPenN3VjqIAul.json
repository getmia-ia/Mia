    {
      "parameters": {
        "jsCode": "// Pega todas as linhas\nconst rows = items.map(i => i.json);\n\n// Função para checar se está aprovado\nconst isApproved = (v) => String(v || '').trim().toLowerCase() === 'aprovado';\n\n// Procura o primeiro item aprovado\nconst first = rows.find(r => \n  isApproved(r.status_linkedin) && r.id_post && r.artigo_blog\n);\n\nif (!first) return []; // Nenhum aprovado encontrado\n\n// Prepara a saída\nconst out = { \n  ...first,\n  status_retorno: first.status // retorna o status\n};\n\nreturn [{ json: out }];\n"
      },
