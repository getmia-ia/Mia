        "tableId": "bms-historico_mensagens",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "mensagem_agente",
              "fieldValue": "=Atenção, um novo participante acabou de se inscrever no evento *{{ $('Edit Fields').first().json.event_name || '-' }}* e precisa da sua aprovação.\n\nSegue abaixo os dados completos do inscrito para sua análise:\n\nO nome completo informado foi *{{ $('Edit Fields').first().json.name || '-' }}* e o CPF cadastrado é *{{ $('Edit Fields').first().json.cpf || '-' }}* com data de nascimento *{{ $('Edit Fields').first().json.birth_date || '-' }}*.\n\nPara contato direto, o email principal é *{{ $('Edit Fields').first().json.email || '-' }}* e o email do assistente é *{{ $('Edit Fields').first().json.assistant_email || '-' }}*, o celular informado foi *{{ $('Edit Fields').first().json.phone || '-' }}* e o telefone fixo é *{{ $('Edit Fields').first().json.cellphone || '-' }}*.\n\nNa parte profissional, a empresa informada foi *{{ $('Edit Fields').first().json.company || '-' }}* e o cargo ocupado é *{{ $('Edit Fields').first().json.position || '-' }}*.\n\nAs redes sociais cadastradas são LinkedIn *{{ $('Edit Fields').first().json.linkedin || '-' }}* e Instagram *{{ $('Edit Fields').first().json.instagram || '-' }}*.\n\nAcesse o painel de gestão para aprovar ou rejeitar este participante."
            },
            {
              "fieldId": "telefone",
              "fieldValue": "={{ $('Loop Over Items').item.json.telefone_gestor }}"
            },
            {
              "fieldId": "nome_app",
              "fieldValue": "BMS-GESTAO"
            }
          ]
        }
      },
