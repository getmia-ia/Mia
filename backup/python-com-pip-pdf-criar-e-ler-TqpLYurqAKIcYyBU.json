    {
      "parameters": {
        "command": "=python3 - << 'EOF'\nfrom pypdf import PdfReader\nimport json\nimport sys\nimport os\n\n# Caminho vindo do n8n (injeção de expressão)\npdf_path = \"{{ $('Edit Fields').item.json.caminho }}\"\n\nif not os.path.exists(pdf_path):\n    print(json.dumps({\n        \"erro\": f\"Arquivo não encontrado: {pdf_path}\"\n    }))\n    sys.exit(1)\n\nreader = PdfReader(pdf_path)\npage = reader.pages[0]\n\ntexto = page.extract_text()\n\nprint(json.dumps({\n    \"mensagem\": \"PDF lido com sucesso\",\n    \"caminho\": pdf_path,\n    \"texto\": texto\n}))\nEOF\n\n "
      },
