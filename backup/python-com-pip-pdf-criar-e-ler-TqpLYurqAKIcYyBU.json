    {
      "parameters": {
        "command": "python3 - << 'EOF'\nfrom fpdf import FPDF\nimport base64\nimport json\n\n# Criar PDF básico\npdf = FPDF()\npdf.add_page()\npdf.set_font(\"Arial\", size=16)\npdf.cell(0, 10, \"Hello World!\", ln=1, align=\"C\")\n\n# Gerar PDF em memória\npdf_bytes = pdf.output(dest=\"S\").encode(\"latin-1\")\n\n# Converter para base64\npdf_b64 = base64.b64encode(pdf_bytes).decode(\"utf-8\")\n\n# Saída JSON no formato que o n8n espera\nprint(json.dumps([{\n    \"json\": {},\n    \"binary\": {\n        \"data\": {\n            \"data\": pdf_b64,\n            \"mimeType\": \"application/pdf\",\n            \"fileName\": \"hello.pdf\"\n        }\n    }\n}]))\nEOF\n"
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -304,
        400
      ],
      "id": "54ebbe57-24ee-4986-a627-794a0d519d5b",
      "name": "cria PDF em memória binário com python"
