      "parameters": {
        "jsCode": "// Dados vindos do webhook\nconst base64 = $json.body.fileBase64;\nconst fileName = $json.body.fileName || 'arquivo.pdf';\nconst mimeType = $json.body.mimeType || 'application/pdf';\n\n// Converte Base64 para Buffer\nconst buffer = Buffer.from(base64, 'base64');\n\n// Retorna no formato esperado pelo n8n\nreturn [\n  {\n    json: {},\n    binary: {\n      data: {\n        data: buffer,\n        fileName,\n        mimeType,\n      },\n    },\n  },\n];\n"
      },
