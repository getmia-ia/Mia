      "parameters": {
        "jsCode": "function sanitizarJSON(str) {\n  if (typeof str !== \"string\") return str;\n  // Substitui caracteres de controle literais por suas versões escapadas\n  return str\n    .replace(/\\n/g, \"\\\\n\")\n    .replace(/\\r/g, \"\\\\r\")\n    .replace(/\\t/g, \"\\\\t\");\n}\n\nfunction desempacotar(valor, maxTentativas = 15) {\n  let atual = valor;\n\n  for (let i = 0; i < maxTentativas; i++) {\n    if (typeof atual === \"string\") {\n      // Tenta parse direto\n      try {\n        atual = JSON.parse(atual);\n        continue;\n      } catch (e) {}\n\n      // Tenta sanitizar e fazer parse\n      try {\n        atual = JSON.parse(sanitizarJSON(atual));\n        continue;\n      } catch (e) {\n        break;\n      }\n    }\n\n    if (atual && typeof atual === \"object\" && !Array.isArray(atual)) {\n      const temDadosReais =\n        atual.fonte !== undefined ||\n        atual.dados_post !== undefined ||\n        atual.horario !== undefined;\n\n      if (temDadosReais) break;\n\n      if (atual.query !== undefined) {\n        atual = atual.query;\n        continue;\n      }\n    }\n\n    break;\n  }\n\n  return atual;\n}\n\n// ─── Ponto de entrada ─────────────────────────────────────────────────────────\nconst entrada = items[0].json;\n\nlet parsed;\n\nif (entrada.fonte !== undefined || entrada.dados_post !== undefined) {\n  parsed = entrada;\n} else if (entrada.query !== undefined) {\n  parsed = desempacotar(entrada.query);\n} else if (typeof entrada === \"string\") {\n  parsed = desempacotar(entrada);\n} else {\n  parsed = entrada;\n}\n\n// ─── Validação mínima ─────────────────────────────────────────────────────────\nif (!parsed || typeof parsed !== \"object\" || (parsed.fonte === undefined && parsed.dados_post === undefined)) {\n  return [{ json: {\n    erro: true,\n    mensagem: \"Falha ao desempacotar dados\",\n    raw: JSON.stringify(items[0].json).slice(0, 500),\n  }}];\n}\n\n// ─── Extração dos campos ──────────────────────────────────────────────────────\nconst fonte         = parsed.fonte         ?? null;\nconst horario       = parsed.horario       ?? null;\nconst dados_post    = parsed.dados_post    ?? {};\nconst dados_cliente = parsed.dados_cliente ?? {};\n\n// ─── Detectar tipo ────────────────────────────────────────────────────────────\nconst CAMPOS_VIDEO     = [\"video\", \"video_caption\"];\nconst CAMPOS_CARROSSEL = [\"imagens\", \"slides\", \"cards\", \"images\"];\nconst temVideo     = CAMPOS_VIDEO.some(c => dados_post[c] != null);\nconst temCarrossel = CAMPOS_CARROSSEL.some(c => dados_post[c] != null);\nlet tipo = \"desconhecido\";\nif (temVideo) tipo = \"video\";\nelse if (temCarrossel) tipo = \"carrossel\";\n\n// ─── Campos base do post ──────────────────────────────────────────────────────\nconst CAMPOS_BASE_POST = [\"id\", \"client\", \"user\", \"user_number_phone\", \"created_at\", \"status\"];\nconst post_base = {};\nfor (const campo of CAMPOS_BASE_POST) {\n  post_base[campo] = dados_post[campo] ?? null;\n}\n\n// ─── Campos específicos por tipo ──────────────────────────────────────────────\nlet post_conteudo = {};\nif (tipo === \"video\") {\n  post_conteudo = {\n    video_url: dados_post.video ?? null,\n    caption:   dados_post.video_caption ?? null,\n  };\n} else if (tipo === \"carrossel\") {\n  const campoSlides = CAMPOS_CARROSSEL.find(c => dados_post[c] != null);\n  const slides = dados_post[campoSlides];\n  post_conteudo = {\n    slides: Array.isArray(slides)\n      ? slides.map((slide, index) => ({\n          numero: index + 1,\n          ...(typeof slide === \"string\" ? { url: slide } : slide),\n        }))\n      : slides,\n    total_slides: Array.isArray(slides) ? slides.length : null,\n    caption: dados_post.caption ?? dados_post.video_caption ?? null,\n  };\n}\n\n// ─── Campos extras do post ────────────────────────────────────────────────────\nconst CAMPOS_CONHECIDOS = [...CAMPOS_BASE_POST, ...CAMPOS_VIDEO, ...CAMPOS_CARROSSEL, \"caption\"];\nconst extras = {};\nfor (const campo of Object.keys(dados_post)) {\n  if (!CAMPOS_CONHECIDOS.includes(campo)) extras[campo] = dados_post[campo];\n}\n\n// ─── Dados do cliente ─────────────────────────────────────────────────────────\nconst CAMPOS_CONHECIDOS_CLIENTE = [\"cliente\", \"ramo\", \"target_audience\", \"keywords_context\", \"criterios_relevancia\"];\nconst cliente = {\n  nome:                 dados_cliente.cliente              ?? null,\n  ramo:                 dados_cliente.ramo                 ?? null,\n  target_audience:      dados_cliente.target_audience      ?? null,\n  keywords:             dados_cliente.keywords_context     ?? null,\n  criterios_relevancia: dados_cliente.criterios_relevancia ?? null,\n};\nfor (const campo of Object.keys(dados_cliente)) {\n  if (!CAMPOS_CONHECIDOS_CLIENTE.includes(campo)) cliente[campo] = dados_cliente[campo];\n}\n\n// ─── Resultado final ──────────────────────────────────────────────────────────\nreturn [{\n  json: {\n    tipo,\n    fonte,\n    horario,\n    post: {\n      ...post_base,\n      ...post_conteudo,\n      ...(Object.keys(extras).length > 0 ? { extras } : {}),\n    },\n    cliente,\n  }\n}];"
      },
