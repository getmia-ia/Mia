    {
      "parameters": {
        "jsCode": "const raw = items[0].json.query;\nconst parsed = JSON.parse(raw);\n\nconst fonte = parsed.fonte ?? null;\nconst horario = parsed.horario ?? null;\nconst dados_post = parsed.dados_post ?? {};\nconst dados_cliente = parsed.dados_cliente ?? {};\n\n// ─── Detectar tipo ───────────────────────────────────────────\nconst CAMPOS_VIDEO = [\"video\", \"video_caption\"];\nconst CAMPOS_CARROSSEL = [\"imagens\", \"slides\", \"cards\", \"images\"];\n\nconst temVideo = CAMPOS_VIDEO.some(c => dados_post[c] != null);\nconst temCarrossel = CAMPOS_CARROSSEL.some(c => dados_post[c] != null);\n\nlet tipo = \"desconhecido\";\nif (temVideo) tipo = \"video\";\nelse if (temCarrossel) tipo = \"carrossel\";\n\n// ─── Campos base do post (presentes em ambos os tipos) ───────\nconst CAMPOS_BASE_POST = [\"id\", \"client\", \"user\", \"user_number_phone\", \"created_at\", \"status\"];\n\nconst post_base = {};\nfor (const campo of CAMPOS_BASE_POST) {\n  post_base[campo] = dados_post[campo] ?? null;\n}\n\n// ─── Campos específicos por tipo ─────────────────────────────\nlet post_conteudo = {};\n\nif (tipo === \"video\") {\n  post_conteudo = {\n    video_url: dados_post.video ?? null,\n    caption: dados_post.video_caption ?? null,\n  };\n} else if (tipo === \"carrossel\") {\n  // Pega o campo de slides independente do nome que vier\n  const campoSlides = CAMPOS_CARROSSEL.find(c => dados_post[c] != null);\n  const slides = dados_post[campoSlides];\n\n  post_conteudo = {\n    slides: Array.isArray(slides)\n      ? slides.map((slide, index) => ({\n          numero: index + 1,\n          ...(typeof slide === \"string\" ? { url: slide } : slide),\n        }))\n      : slides,\n    total_slides: Array.isArray(slides) ? slides.length : null,\n    caption: dados_post.caption ?? dados_post.video_caption ?? null,\n  };\n}\n\n// ─── Campos extras (qualquer campo não mapeado acima) ─────────\nconst CAMPOS_CONHECIDOS = [\n  ...CAMPOS_BASE_POST,\n  ...CAMPOS_VIDEO,\n  ...CAMPOS_CARROSSEL,\n  \"caption\",\n];\n\nconst extras = {};\nfor (const campo of Object.keys(dados_post)) {\n  if (!CAMPOS_CONHECIDOS.includes(campo)) {\n    extras[campo] = dados_post[campo];\n  }\n}\n\n// ─── Dados do cliente ─────────────────────────────────────────\nconst cliente = {\n  nome: dados_cliente.cliente ?? null,\n  ramo: dados_cliente.ramo ?? null,\n  target_audience: dados_cliente.target_audience ?? null,\n  keywords: dados_cliente.keywords_context ?? null,\n  criterios_relevancia: dados_cliente.criterios_relevancia ?? null,\n};\n\n// ─── Campos extras do cliente (qualquer campo não mapeado) ────\nconst CAMPOS_CONHECIDOS_CLIENTE = [\"cliente\", \"ramo\", \"target_audience\", \"keywords_context\", \"criterios_relevancia\"];\n\nfor (const campo of Object.keys(dados_cliente)) {\n  if (!CAMPOS_CONHECIDOS_CLIENTE.includes(campo)) {\n    cliente[campo] = dados_cliente[campo];\n  }\n}\n\n// ─── Resultado final ──────────────────────────────────────────\nconst resultado = {\n  tipo,\n  fonte,\n  horario,\n  post: {\n    ...post_base,\n    ...post_conteudo,\n    ...(Object.keys(extras).length > 0 ? { extras } : {}),\n  },\n  cliente,\n};\n\nreturn [{ json: resultado }];"
      },
